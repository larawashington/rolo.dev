---
import { LINKS } from '../lib/links';
const year = new Date().getFullYear();

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';

const leftNav = [
  { label: 'Home',           href: base,                    external: false },
  { label: 'FAQs',           href: `${base}faq`,            external: false },
  { label: 'Tech + Process', href: `${base}tech+process`,   external: false },
  { label: 'GitHub',         href: LINKS.github,            external: true  },
];

const rightNav = [
  { label: 'About the Founder', href: `${base}about-the-founder`, external: false },
  { label: 'Contact',           href: `${base}contact`,           external: false },
  { label: 'LinkedIn',          href: LINKS.linkedin,             external: true  },
];
---
<footer class="site-footer">
  <div class="shell site-footer__inner">
    <div class="site-footer__brand">
      <a class="footer-brand__lockup" href={base} aria-label="Project Rolo — home">
        <img
          class="footer-brand__mark pixel"
          src={`${base}rolo-logo.png`}
          alt=""
          width="52"
          height="52"
        />
        <span class="footer-brand__name">
          <span>PROJECT</span>&nbsp;<span class="footer-brand__rolo">ROLO</span>
        </span>
      </a>
      <p class="footer-tag">
        A free, open-source desktop companion.
      </p>
    </div>

    <nav class="site-footer__nav site-footer__nav--primary" aria-label="Site">
      <ul>
        {leftNav.map(item => (
          <li>
            <a
              href={item.href}
              {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
            >
              {item.label}
              {item.external && <span class="ext-arrow" aria-hidden="true">&nbsp;↗</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <nav class="site-footer__nav site-footer__nav--social" aria-label="More">
      <ul>
        {rightNav.map(item => (
          <li>
            <a
              href={item.href}
              {...(item.external ? { target: '_blank', rel: 'noopener' } : {})}
            >
              {item.label}
              {item.external && <span class="ext-arrow" aria-hidden="true">&nbsp;↗</span>}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="shell site-footer__legal">
    <hr class="pixel-rule" />
    <p class="site-footer__copy">
      &copy; {year} Project Rolo. All rights and pixels reserved.
    </p>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 2;
    background: var(--bg);
    padding: 3rem 0 2rem;
    /* Divider line — lives on the footer so every page gets it
       consistently, regardless of what section sits above. */
    border-top: 2px solid var(--ink);
  }

  .site-footer__inner {
    display: grid;
    grid-template-columns: minmax(0, 1.4fr) minmax(0, 1fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 3.5rem);
    align-items: start;
  }
  @media (max-width: 720px) {
    .site-footer__inner { grid-template-columns: 1fr; gap: 2.25rem; }
  }

  /* --- Brand lockup — logo + wordmark inline, tagline below, left-aligned -- */
  .site-footer__brand {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .footer-brand__lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: var(--ink);
    line-height: 1;
    transition: transform 140ms var(--ease-soft);
    width: max-content;
  }
  .footer-brand__lockup:hover { transform: translate(-1px, -1px); }
  .footer-brand__mark {
    width: 52px;
    height: 52px;
    background: transparent;
    border: 0;
    box-shadow: none;
    flex-shrink: 0;
  }
  .footer-brand__name {
    font-family: var(--display);
    font-size: 1.15rem;
    letter-spacing: 0.04em;
    line-height: 1;
    padding-top: 2px;
    white-space: nowrap;
  }
  .footer-brand__rolo { color: var(--rolo); }

  .footer-tag {
    font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--ink-soft);
    line-height: 1.55;
    margin: 0;
    white-space: nowrap;
  }
  /* Let it wrap again on very narrow viewports where nowrap would overflow */
  @media (max-width: 380px) {
    .footer-tag { white-space: normal; }
  }

  /* --- Footer nav lists ------------------------------------------------ */
  .site-footer__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .site-footer__nav a {
    font-family: var(--display);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    text-decoration: none;
    padding: 0.25rem 0;
    display: inline-flex;
    align-items: center;
    border-bottom: 2px solid transparent;
    transition: color 160ms var(--ease-soft),
                border-color 160ms var(--ease-soft),
                transform 140ms var(--ease-soft);
  }
  .site-footer__nav a:hover {
    color: var(--rolo-deep);
    border-bottom-color: var(--rolo);
    transform: translateX(2px);
  }
  .ext-arrow { color: var(--ink-soft); }
  .site-footer__nav a:hover .ext-arrow { color: var(--rolo-deep); }

  /* --- Bottom row ------------------------------------------------------- */
  .site-footer__legal {
    margin-top: clamp(2.5rem, 5vw, 3.25rem);
  }
  .site-footer__legal .pixel-rule {
    margin-bottom: 1.25rem;
  }
  .site-footer__copy {
    font-family: ui-monospace, 'SF Mono', 'JetBrains Mono', monospace;
    font-size: 0.78rem;
    color: var(--ink-soft);
    margin: 0;
  }
</style>
