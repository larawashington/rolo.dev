---
import { LINKS } from '../lib/links';
const year = new Date().getFullYear();
---
<footer class="site-footer">
  <div class="shell">
    <hr class="pixel-rule footer__rule" />

    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <p class="footer-logo">PROJECT ROLO</p>
        <p class="footer-tag">
          A free, open-source desktop companion.<br />
          Lorem ipsum dolor sit amet, consectetur adipiscing elit.
        </p>
      </div>

      <div class="site-footer__social" aria-label="Find us elsewhere">
        <p class="footer-heading">Find us</p>
        <ul>
          <li>
            <a href={LINKS.github} target="_blank" rel="noopener">
              GitHub
              <span class="footer-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
          <li>
            <a href={LINKS.linkedin} target="_blank" rel="noopener">
              LinkedIn
              <span class="footer-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
          <li>
            {/* PLACEHOLDER: email — swap when real address is provided */}
            <a href={LINKS.email}>
              Email
              <span class="footer-arrow" aria-hidden="true">&rarr;</span>
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="site-footer__bottom">
      <small>&copy; {year} Project Rolo. Open source with love.</small>
      <small class="footer-meta">Lorem ipsum &middot; dolor sit amet</small>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 2;
    background: var(--bg);
    padding: 3rem 0 2rem;
    margin-top: 4rem;
  }
  .footer__rule { opacity: 0.6; margin-bottom: 2.5rem; }

  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.6fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 4rem);
    align-items: start;
  }
  @media (max-width: 720px) {
    .site-footer__grid { grid-template-columns: 1fr; gap: 2rem; }
  }

  .footer-logo {
    font-family: var(--display);
    font-size: 0.85rem;
    color: var(--ink);
    letter-spacing: 0.04em;
    margin-bottom: 0.85rem;
  }
  .footer-tag {
    font-family: var(--body);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 38ch;
  }

  .footer-heading {
    font-family: var(--display);
    font-size: 0.65rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-soft);
    margin-bottom: 1rem;
  }
  .site-footer__social ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.6rem;
  }
  .site-footer__social a {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 2px solid transparent;
    padding-bottom: 2px;
    font-weight: 600;
    transition: color 160ms var(--ease-soft),
                border-color 160ms var(--ease-soft),
                transform 140ms var(--ease-soft);
  }
  .site-footer__social a:hover {
    color: var(--rolo-deep);
    border-bottom-color: var(--rolo);
    transform: translateX(2px);
  }
  .footer-arrow {
    font-family: var(--display);
    font-size: 0.75rem;
    color: var(--rolo);
  }

  .site-footer__bottom {
    margin-top: 2.5rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--rule);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    color: var(--ink-soft);
    font-size: 0.85rem;
  }
  @media (max-width: 540px) {
    .site-footer__bottom { flex-direction: column; align-items: flex-start; }
  }
  .footer-meta { font-style: italic; }
</style>
