---
import { LINKS } from '../lib/links';
const year = new Date().getFullYear();

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---
<footer class="site-footer">
  <div class="shell">
    <hr class="pixel-rule footer__rule" />

    <div class="site-footer__grid">
      <div class="site-footer__brand">
        <a class="footer-brand" href={base} aria-label="Project Rolo — home">
          <img
            class="footer-brand__mark pixel"
            src={`${base}rolo-logo.png`}
            alt=""
            width="48"
            height="48"
          />
          <span class="footer-brand__name">
            <span>PROJECT</span>&nbsp;<span class="footer-brand__rolo">ROLO</span>
          </span>
        </a>
        <p class="footer-tag">
          A free, open-source desktop companion.
        </p>
      </div>

      <nav class="site-footer__nav" aria-label="Find us elsewhere">
        <p class="subhead footer-heading">Find us</p>
        <ul>
          <li>
            <a href={LINKS.github} target="_blank" rel="noopener">GitHub</a>
          </li>
          <li>
            <a href={LINKS.linkedin} target="_blank" rel="noopener">LinkedIn</a>
          </li>
          <li>
            {/* PLACEHOLDER: email — swap when real address is provided */}
            <a href={LINKS.email}>Email</a>
          </li>
        </ul>
      </nav>
    </div>

    <div class="site-footer__bottom">
      <small>&copy; {year} Project Rolo. Open source with love.</small>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    position: relative;
    z-index: 2;
    background: var(--bg);
    padding: 3rem 0 2rem;
    margin-top: 4rem;
  }
  .footer__rule { opacity: 0.6; margin-bottom: 2.75rem; }

  .site-footer__grid {
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(0, 1fr);
    gap: clamp(2rem, 6vw, 4rem);
    align-items: start;
  }
  @media (max-width: 720px) {
    .site-footer__grid { grid-template-columns: 1fr; gap: 2.25rem; }
  }

  /* --- Brand lockup ----------------------------------------------------- */
  .footer-brand {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--display);
    line-height: 1;
    margin-bottom: 1rem;
    transition: transform 140ms var(--ease-soft);
  }
  .footer-brand:hover { transform: translate(-1px, -1px); }
  .footer-brand__mark {
    width: 48px;
    height: 48px;
    background: transparent;
    border: 0;
    box-shadow: none;
  }
  .footer-brand__name {
    font-size: 1.05rem;
    letter-spacing: 0.04em;
    padding-top: 2px;
    white-space: nowrap;
  }
  .footer-brand__rolo { color: var(--rolo); }

  .footer-tag {
    font-family: var(--body);
    color: var(--ink-soft);
    line-height: 1.55;
    max-width: 38ch;
    margin: 0;
  }

  /* --- Find us nav ------------------------------------------------------ */
  .footer-heading {
    /* uses global .subhead — uppercase tracked, rolo-deep */
    margin: 0 0 0.85rem;
  }
  .site-footer__nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 0.55rem;
  }
  .site-footer__nav a {
    font-family: var(--display);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--ink);
    text-decoration: none;
    padding: 0.25rem 0;
    display: inline-flex;
    align-items: center;
    border-bottom: 2px solid transparent;
    transition: color 160ms var(--ease-soft),
                border-color 160ms var(--ease-soft),
                transform 140ms var(--ease-soft);
  }
  .site-footer__nav a:hover {
    color: var(--rolo-deep);
    border-bottom-color: var(--rolo);
    transform: translateX(2px);
  }

  /* --- Bottom row ------------------------------------------------------- */
  .site-footer__bottom {
    margin-top: 2.75rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--rule);
    color: var(--ink-soft);
    font-size: 0.85rem;
  }
</style>
