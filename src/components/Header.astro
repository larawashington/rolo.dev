---
import { LINKS } from '../lib/links';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const path = Astro.url.pathname.replace(base, '/');

const nav = [
  { label: 'Home',          href: base },
  { label: 'FAQ',           href: `${base}faq` },
  { label: 'Tech + Process', href: `${base}tech+process` },
  { label: 'Contact',       href: `${base}contact` },
];
---
<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href={base} aria-label="Project Rolo — home">
      <img class="brand__mark pixel" src={`${base}rolo-logo.png`} alt="" width="52" height="52" />
      <span class="brand__name">
        <span class="brand__project">PROJECT</span>&nbsp;<span class="brand__rolo">ROLO</span>
      </span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map(item => {
          const target = item.href.replace(base, '/');
          const isActive =
            (item.href === base && (path === '/' || path === '')) ||
            (item.href !== base && path === target);
          return (
            <li>
              <a href={item.href} class:list={['nav-link', isActive && 'is-active']}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    padding: 1.25rem 0;
    border-bottom: 2px solid var(--ink);
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.9rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--display);
    letter-spacing: 0.04em;
    line-height: 1;
    transition: transform 140ms var(--ease-soft);
  }
  .brand:hover { transform: translate(-1px, -1px); }

  /* Naked logo — no frame, just the artwork. Pixel art so crisp at any size. */
  .brand__mark {
    width: 52px;
    height: 52px;
    background: transparent;
    border: 0;
    box-shadow: none;
  }

  /* Wordmark scaled to the logo: roughly half the logo's height in cap-size
     so the two read as a single locked-up mark. */
  .brand__name {
    font-size: 1.15rem;
    line-height: 1;
    padding-top: 2px;
    white-space: nowrap;
  }
  .brand__rolo { color: var(--rolo); }

  /* Nav — pixel font, uniform sizing. Hover lifts into the same chunky
     bordered button vocabulary used on CTAs. */
  .site-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
    align-items: center;
  }
  .nav-link {
    font-family: var(--display);
    font-weight: 400;
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    color: var(--ink-soft);
    padding: 0.7rem 0.85rem;
    text-decoration: none;
    border: 2px solid transparent;
    border-radius: 0;
    line-height: 1;
    transition: color 160ms var(--ease-soft),
                background 160ms var(--ease-soft),
                border-color 160ms var(--ease-soft),
                box-shadow 140ms var(--ease-soft),
                transform 140ms var(--ease-soft);
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--ink);
    background: var(--paper);
    border-color: var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    transform: translate(-1px, -1px);
    outline: none;
  }
  .nav-link.is-active {
    color: var(--ink);
    border-bottom: 2px solid var(--rolo);
  }

  @media (max-width: 820px) {
    .site-header__inner { flex-wrap: wrap; gap: 0.85rem; }
    .brand__mark { width: 44px; height: 44px; }
    .brand__name { font-size: 0.95rem; }
    .nav-link { font-size: 0.55rem; padding: 0.55rem 0.6rem; }
  }
  @media (max-width: 540px) {
    .nav-link { font-size: 0.5rem; padding: 0.5rem 0.45rem; }
  }
</style>
