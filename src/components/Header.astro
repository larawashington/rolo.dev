---
import { LINKS } from '../lib/links';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const path = Astro.url.pathname.replace(base, '/');

const nav = [
  { label: 'Home',          href: base },
  { label: 'FAQ',           href: `${base}faq` },
  { label: 'Tech + Process', href: `${base}tech+process` },
  { label: 'Contact',       href: `${base}contact` },
];
---
<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href={base} aria-label="Project Rolo — home">
      <img class="brand__mark pixel" src={`${base}rolo-logo.png`} alt="" width="48" height="48" />
      <span class="brand__name">PROJECT ROLO</span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map(item => {
          const target = item.href.replace(base, '/');
          const isActive =
            (item.href === base && (path === '/' || path === '')) ||
            (item.href !== base && path === target);
          return (
            <li>
              <a href={item.href} class:list={['nav-link', isActive && 'is-active']}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    z-index: 10;
    padding: 1.25rem 0;
    border-bottom: 2px solid var(--ink);
    background: var(--bg);
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.7rem;
    text-decoration: none;
    color: var(--ink);
    font-family: var(--display);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    line-height: 1;
    transition: transform 140ms var(--ease-soft);
  }
  .brand:hover { transform: translate(-1px, -1px); }
  .brand__mark {
    width: 44px;
    height: 44px;
    border: 2px solid var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    background: var(--paper);
  }
  .brand__name {
    /* tiny pixel font — Press Start 2P at very small size keeps it readable */
    padding-top: 2px;
  }

  .site-nav ul {
    display: flex;
    gap: 0.35rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    font-family: var(--body);
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink-soft);
    padding: 0.45rem 0.85rem;
    text-decoration: none;
    border: 2px solid transparent;
    border-radius: 0;
    transition: color 160ms var(--ease-soft),
                background 160ms var(--ease-soft),
                border-color 160ms var(--ease-soft),
                box-shadow 140ms var(--ease-soft),
                transform 140ms var(--ease-soft);
  }
  .nav-link:hover,
  .nav-link:focus-visible {
    color: var(--ink);
    background: var(--paper);
    border-color: var(--ink);
    box-shadow: 3px 3px 0 var(--ink);
    transform: translate(-1px, -1px);
    outline: none;
  }
  .nav-link.is-active {
    color: var(--ink);
    border-bottom: 2px solid var(--rolo);
  }

  @media (max-width: 720px) {
    .site-header__inner { flex-wrap: wrap; gap: 0.75rem; }
    .brand__name { font-size: 0.7rem; }
    .nav-link { font-size: 0.85rem; padding: 0.35rem 0.6rem; }
  }
</style>
