---
const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
const path = Astro.url.pathname.replace(base, '/');

const nav = [
  { label: 'home',     href: base },
  { label: 'faq',      href: `${base}faq` },
  { label: 'contact',  href: `${base}contact` },
];
---
<header class="site-header">
  <div class="shell site-header__inner">
    <a class="brand" href={base} aria-label="Rolo home">
      <span class="brand__mark" aria-hidden="true">
        {/* Tiny pixel hood-tip — abbreviated brand mark, not full Rolo */}
        <svg width="28" height="28" viewBox="0 0 14 14" shape-rendering="crispEdges" aria-hidden="true">
          <rect x="5" y="0" width="4" height="2" fill="#000000"/>
          <rect x="4" y="2" width="3" height="2" fill="#F06449"/>
          <rect x="7" y="2" width="2" height="2" fill="#E28954"/>
          <rect x="3" y="2" width="1" height="2" fill="#000000"/>
          <rect x="9" y="2" width="1" height="2" fill="#000000"/>
          <rect x="3" y="4" width="1" height="2" fill="#000000"/>
          <rect x="4" y="4" width="1" height="2" fill="#CF3E22"/>
          <rect x="5" y="4" width="4" height="2" fill="#F06449"/>
          <rect x="9" y="4" width="1" height="2" fill="#E28954"/>
          <rect x="10" y="4" width="1" height="2" fill="#000000"/>
          <rect x="2" y="6" width="1" height="4" fill="#000000"/>
          <rect x="3" y="6" width="1" height="4" fill="#CF3E22"/>
          <rect x="4" y="6" width="6" height="4" fill="#DFF8EB"/>
          <rect x="6" y="7" width="1" height="1" fill="#3D6084"/>
          <rect x="9" y="7" width="1" height="1" fill="#3D6084"/>
          <rect x="6" y="9" width="3" height="1" fill="#3D6084"/>
          <rect x="10" y="6" width="1" height="4" fill="#E28954"/>
          <rect x="11" y="6" width="1" height="4" fill="#000000"/>
          <rect x="3" y="10" width="8" height="1" fill="#000000"/>
        </svg>
      </span>
      <span class="brand__name">rolo<span class="brand__tld">.dev</span></span>
    </a>

    <nav class="site-nav" aria-label="Primary">
      <ul>
        {nav.map(item => {
          const isActive = (item.href === base && (path === '/' || path === '')) ||
                           (item.href !== base && path.startsWith(item.href.replace(base, '/')));
          return (
            <li>
              <a href={item.href} class:list={['nav-link', isActive && 'is-active']}>
                {item.label}
              </a>
            </li>
          );
        })}
      </ul>
    </nav>
  </div>
</header>

<style>
  .site-header {
    position: relative;
    z-index: 10;
    padding: 1.5rem 0 0.5rem;
  }
  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
  }

  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--navy);
    font-family: 'Silkscreen', monospace;
    font-size: 1.4rem;
    letter-spacing: 0.04em;
  }
  .brand:hover { color: var(--sage-deep); }
  .brand__mark {
    display: inline-flex;
    width: 36px; height: 36px;
    align-items: center; justify-content: center;
    background: var(--bg-tint);
    border: 2px solid var(--navy);
    border-radius: 2px;
    box-shadow: 3px 3px 0 var(--navy);
  }
  .brand__name { line-height: 1; }
  .brand__tld {
    color: var(--sage-deep);
  }

  .site-nav ul {
    display: flex;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .nav-link {
    font-family: 'VT323', monospace;
    font-size: 1.4rem;
    letter-spacing: 0.08em;
    color: var(--navy-soft);
    padding: 0.4rem 0.85rem;
    text-decoration: none;
    border: 2px solid transparent;
    border-radius: 2px;
    transition: all 160ms var(--ease-soft);
  }
  .nav-link:hover {
    color: var(--navy);
    background: var(--bg-tint);
    border-color: var(--navy);
    box-shadow: 3px 3px 0 var(--navy);
    transform: translate(-1px, -1px);
  }
  .nav-link.is-active {
    color: var(--navy);
    border-bottom: 2px solid var(--rolo);
  }

  @media (max-width: 540px) {
    .site-header__inner { flex-wrap: wrap; }
    .brand__name { font-size: 1.2rem; }
    .nav-link { font-size: 1.2rem; padding: 0.3rem 0.6rem; }
  }
</style>
