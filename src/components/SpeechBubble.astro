---
/**
 * SpeechBubble — pixel-art speech bubble with chunky 2px navy outline to match
 * Rolo's outline aesthetic. Tail points down-left toward Rolo's head.
 */
interface Props {
  text?: string;
  /** which corner the tail points from. */
  tail?: 'bottom-left' | 'bottom-right';
  class?: string;
}

const { text = 'hi', tail = 'bottom-left', class: className = '' } = Astro.props;
---
<div class={`bubble bubble--${tail} ${className}`} aria-hidden="false">
  <span class="bubble__text">{text}</span>
  <span class="bubble__tail" aria-hidden="true"></span>
</div>

<style>
  .bubble {
    --bubble-bg: #FAF6EC;
    --bubble-outline: #2C3E50;
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem 0.85rem;
    background: var(--bubble-bg);
    border: 4px solid var(--bubble-outline);
    border-radius: 2px;
    /* Pixel-stepped outer "shadow" effect — second outline offset by 4px gives
       the corner-staircase look without anti-aliased shadows. */
    box-shadow:
      4px 4px 0 var(--bubble-outline),
      8px 8px 0 #6B8E6F33;
    font-family: 'Silkscreen', 'VT323', monospace;
    font-size: clamp(2rem, 4vw, 3.25rem);
    color: var(--bubble-outline);
    letter-spacing: 0.05em;
    line-height: 1;
    transform: rotate(-1.2deg);
    animation: bubble-wobble 4.6s ease-in-out infinite;
    transform-origin: bottom right;
  }

  .bubble__text {
    /* Tiny baseline lift so 'hi' sits centered visually inside the chunky border. */
    transform: translateY(2px);
  }

  /* Pixel tail — built from two stacked squares to read as a staircase point. */
  .bubble__tail {
    position: absolute;
    width: 16px;
    height: 16px;
    background: var(--bubble-bg);
    border-left: 4px solid var(--bubble-outline);
    border-bottom: 4px solid var(--bubble-outline);
    bottom: -16px;
  }
  .bubble--bottom-left .bubble__tail {
    left: 24px;
    /* extra bottom block to extend the tail another step */
    box-shadow:
      -4px 4px 0 -2px var(--bubble-bg),
      0 4px 0 var(--bubble-outline);
  }
  .bubble--bottom-right .bubble__tail {
    right: 24px;
    border-left: none;
    border-right: 4px solid var(--bubble-outline);
  }

  /* A second mini-block to make the tail look like a pixel staircase rather than a triangle. */
  .bubble__tail::after {
    content: '';
    position: absolute;
    width: 8px;
    height: 8px;
    background: var(--bubble-bg);
    border-left: 4px solid var(--bubble-outline);
    border-bottom: 4px solid var(--bubble-outline);
    left: -4px;
    bottom: -12px;
  }
</style>
