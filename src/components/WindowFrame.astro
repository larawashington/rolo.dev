---
/**
 * WindowFrame — pixel-art styled macOS-ish window.
 * Chunky 2px ink border + offset shadow, three small button dots in the
 * top-left corner (no real close/min/max icons per wireframe). Rounded
 * corners use the printmaking trick: real radius on the outer container
 * plus a subtle 4-corner "notch" pixel feel from the border treatment.
 *
 * `accent` colours the chrome (title bar) to signal slide context.
 *   paper — default warm bg
 *   sun   — warm yellow
 *   moon  — cool blue
 *   rolo  — Rolo orange
 */
interface Props {
  title?: string;
  /** subdued (peek) variant for adjacent slides in a carousel */
  variant?: 'active' | 'peek';
  /** chrome accent colour */
  accent?: 'paper' | 'sun' | 'moon' | 'rolo';
  class?: string;
}
const {
  title = '',
  variant = 'active',
  accent = 'paper',
  class: className = '',
} = Astro.props;
---
<div class:list={['window', `window--${variant}`, `window--accent-${accent}`, className]}>
  <div class="window__chrome">
    <div class="window__dots" aria-hidden="true">
      <span class="window__dot"></span>
      <span class="window__dot"></span>
      <span class="window__dot"></span>
    </div>
    {title && <span class="window__title">{title}</span>}
  </div>

  <div class="window__body">
    <slot />
  </div>
</div>

<style>
  .window {
    background: var(--paper);
    border: 2px solid var(--ink);
    border-radius: 10px;
    box-shadow: var(--shadow-pixel);
    overflow: hidden;
    display: grid;
    grid-template-rows: auto 1fr;
    position: relative;
    transition: transform 240ms var(--ease-soft),
                box-shadow 240ms var(--ease-soft),
                opacity 240ms var(--ease-soft);
  }
  .window--peek {
    opacity: 0.55;
    transform: scale(0.92);
    box-shadow: 4px 4px 0 var(--ink);
    filter: saturate(0.85);
  }

  .window__chrome {
    background: var(--rule);
    border-bottom: 2px solid var(--ink);
    padding: 0.75rem 1rem;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    min-height: 44px;
  }

  /* Accent variants — fill the chrome with the slide's colour.
     paper uses --rule, a neutral tan that pops against both
     page bg and the lighter paper body. */
  .window--accent-sun  .window__chrome { background: var(--sun); }
  .window--accent-moon .window__chrome { background: var(--moon); }
  .window--accent-rolo .window__chrome { background: var(--rolo); }

  .window__dots {
    display: inline-flex;
    gap: 7px;
  }
  .window__dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 1.5px solid var(--ink);
    background: var(--paper);
  }
  /* per-dot colour reads as macOS without the actual icons */
  .window__dot:nth-child(1) { background: var(--rolo); }
  .window__dot:nth-child(2) { background: var(--sun); }
  .window__dot:nth-child(3) { background: var(--ok); }

  /* Title is the slide's headline — pixel font, larger and confident.
     This is the H3 for the slide, hence prominent. */
  .window__title {
    font-family: var(--display);
    font-size: clamp(0.85rem, 1.1vw, 1rem);
    line-height: 1;
    letter-spacing: 0.04em;
    color: var(--rolo-deep);
    margin: 0 auto;
    padding-right: 52px; /* visually centers despite left dots */
  }

  /* Title contrast adapts to the chrome colour.
     On rolo/moon chrome the deep-orange disappears — switch to paper. */
  .window--accent-rolo .window__title,
  .window--accent-moon .window__title { color: var(--paper); }
  .window--accent-sun  .window__title { color: var(--ink); }

  .window__body {
    background: var(--paper);
    padding: 0;
    min-height: 0;
  }
</style>
