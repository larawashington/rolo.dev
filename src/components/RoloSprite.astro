---
/**
 * RoloSprite — pixel-perfect canonical idle pose.
 *
 * The grid below is transcribed verbatim from kb-rolo/wiki/appearance/canonical-pose.md.
 * Every pixel is one of K/R/S/H/F/E or transparent. Width 64, height 62.
 * At build time we run-length-encode each row into <rect> elements so the SVG
 * stays small while remaining pixel-exact.
 */
interface Props {
  /** rendered display size, in px (sprite width). */
  size?: number;
  /** include an idle bob animation. */
  animated?: boolean;
  /** className to pass through. */
  class?: string;
  /** aria-label. */
  label?: string;
}

const {
  size = 320,
  animated = true,
  class: className = '',
  label = 'Rolo, a small pixel-art creature with a red hood, mint-green face, and tiny blue eyes',
} = Astro.props;

const palette: Record<string, string> = {
  K: '#000000',
  R: '#F06449',
  S: '#CF3E22',
  H: '#E28954',
  F: '#DFF8EB',
  E: '#3D6084',
};

// Canonical idle frame 0, transcribed from canonical-pose.md.
const grid = [
  '........................KKKKKKKKKK..............................',
  '........................KKKKKKKKKK..............................',
  '......................KKRRRRRRHHHHKK............................',
  '......................KKRRRRRRHHHHKK............................',
  '........................KKRRRRRRRRHHKK..........................',
  '........................KKRRRRRRRRHHKK..........................',
  '..........................KKRRRRRRRRHHKK........................',
  '..........................KKRRRRRRRRHHKK........................',
  '........................KKSSRRRRRRRRRRHHKKKK....................',
  '........................KKSSRRRRRRRRRRHHKKKK....................',
  '......................KKSSRRRRRRRRRRRRRRRRHHKKKK................',
  '......................KKSSRRRRRRRRRRRRRRRRHHKKKK................',
  '..................KKKKSSRRRRRRRRRRRRRRRRRRRRRRHHKK..............',
  '..................KKKKSSRRRRRRRRRRRRRRRRRRRRRRHHKK..............',
  '................KKSSSSRRRRRRRRRRRRRRRRRRRRRRRRRRHHKK............',
  '................KKSSSSRRRRRRRRRRRRRRRRRRRRRRRRRRHHKK............',
  '..............KKSSSSRRRRFFFFFFFFFFFFFFFFFFRRRRRRRRHHKK..........',
  '..............KKSSSSRRRRFFFFFFFFFFFFFFFFFFRRRRRRRRHHKK..........',
  '..............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFRRRRRRHHKK..........',
  '..............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFRRRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFEEFFFFFFFFFFEEFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFEEFFFFFFFFFFEEFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFEEEEEEEEEEFFFFFFFFRRRRHHKK..........',
  '............KKSSRRRRFFFFFFFFEEEEEEEEEEFFFFFFFFRRRRHHKK..........',
  '..............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFRRRRRRKK............',
  '..............KKSSRRRRFFFFFFFFFFFFFFFFFFFFFFRRRRRRKK............',
  '................KKSSRRRRFFFFFFFFFFFFFFFFFFRRRRRRKK..............',
  '................KKSSRRRRFFFFFFFFFFFFFFFFFFRRRRRRKK..............',
  '..................KKKKSSRRRRRRRRRRRRRRRRRRRRKKKK................',
  '..................KKKKSSRRRRRRRRRRRRRRRRRRRRKKKK................',
  '......................KKKKSSRRRRRRRRRRRRKKKK....................',
  '......................KKKKSSRRRRRRRRRRRRKKKK....................',
  '..........................KKSSRRRRRRRRKK........................',
  '..........................KKSSRRRRRRRRKK........................',
  '......................KKKKSSRRRRRRRRRRRRKKKK....................',
  '......................KKKKSSRRRRRRRRRRRRKKKK....................',
  '....................KKSSSSRRRRRRRRRRRRRRRRHHKK..................',
  '....................KKSSSSRRRRRRRRRRRRRRRRHHKK..................',
  '....................KKSSKKSSRRRRRRRRRRRRKKRRKK..................',
  '....................KKSSKKSSRRRRRRRRRRRRKKRRKK..................',
  '......................KK..KKRRRRRRRRRRKK..KK....................',
  '......................KK..KKRRRRRRRRRRKK..KK....................',
  '..........................KKRRRRRRRRRRKK........................',
  '..........................KKRRRRRRRRRRKK........................',
  '..........................KKRRRRRRRRRRKK........................',
  '..........................KKRRRRRRRRRRKK........................',
  '..........................KKRRRRRRRRRRKK........................',
  '..........................KKRRRRRRRRRRKK........................',
  '..........................KKRRRRKKRRRRKK........................',
  '..........................KKRRRRKKRRRRKK........................',
  '........................KKSSSSKK..KKRRRRKK......................',
  '........................KKSSSSKK..KKRRRRKK......................',
  '......................KKSSSSKK......KKRRRRKK....................',
  '......................KKSSSSKK......KKRRRRKK....................',
  '........................KKKK..........KKKK......................',
  '........................KKKK..........KKKK......................',
];

// Run-length-encode each row into <rect> records.
type Rect = { x: number; y: number; w: number; fill: string };
const rects: Rect[] = [];
for (let y = 0; y < grid.length; y++) {
  const row = grid[y];
  let x = 0;
  while (x < row.length) {
    const ch = row[x];
    if (ch === '.') { x++; continue; }
    let run = 1;
    while (x + run < row.length && row[x + run] === ch) run++;
    rects.push({ x, y, w: run, fill: palette[ch]! });
    x += run;
  }
}

const aspectRatio = grid.length / grid[0].length;
const renderHeight = Math.round(size * aspectRatio);
---
<svg
  class={`rolo-sprite ${animated ? 'rolo-sprite--animated' : ''} ${className}`}
  width={size}
  height={renderHeight}
  viewBox="0 0 64 62"
  xmlns="http://www.w3.org/2000/svg"
  role="img"
  aria-label={label}
  shape-rendering="crispEdges"
>
  <g>
    {rects.map(({ x, y, w, fill }) => (
      <rect x={x} y={y} width={w} height={1} fill={fill} />
    ))}
  </g>
</svg>

<style>
  .rolo-sprite {
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    display: block;
    /* Drop a soft shadow under Rolo to ground him on the page. Soft, not pixel — depth contrast. */
    filter: drop-shadow(0 12px 14px rgba(44, 62, 80, 0.18));
  }
  .rolo-sprite--animated {
    animation: rolo-bob 3.2s ease-in-out infinite;
    transform-origin: bottom center;
    will-change: transform;
  }
</style>
