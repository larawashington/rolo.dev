---
interface Props {
  title?: string;
  description?: string;
  pageId?: string;
}

const {
  title = 'Project Rolo — a free, open-source desktop companion',
  description = 'Project Rolo is a free, open-source desktop companion. A tiny pixel creature who lives on your screen and makes your day a little brighter.',
  pageId,
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f4e4c1" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:image" content={`${base}rolo-logo.png`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:image" content={`${base}rolo-logo.png`} />

    {/* Fonts — Press Start 2P (pixel display), Encode Sans (body) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=Encode+Sans:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    {/* Favicon */}
    <link rel="icon" type="image/png" href={`${base}rolo-favicon.png`} />
    <link rel="apple-touch-icon" href={`${base}rolo-favicon.png`} />
  </head>
  <body data-page={pageId}>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
