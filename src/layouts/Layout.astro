---
interface Props {
  title?: string;
  description?: string;
  pageId?: string;
}

const {
  title = 'Rolo — your cosy desktop companion',
  description = 'Rolo is a tiny pixel-art creature who lives on your desktop. He walks around, reacts to the mouse, and eats files you drag onto him.',
  pageId,
} = Astro.props;

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#F5EFE0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Open Graph */}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />

    {/* Fonts — Silkscreen (pixel display), VT323 (pixel terminal), Fraunces (serif body) */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Silkscreen:wght@400;700&family=VT323&family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,500;0,9..144,600;1,9..144,400&display=swap"
      rel="stylesheet"
    />

    {/* Favicon — tiny pixel Rolo silhouette */}
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  </head>
  <body data-page={pageId}>
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
