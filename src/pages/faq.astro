---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { LINKS } from "../lib/links";

// ---------------------------------------------------------------------------
// FAQ content — audited copy. Sections map 1:1 onto the homepage pillar accent
// system, so each section's accent rule + nav-pill dot picks up that color.
// ---------------------------------------------------------------------------
type Section = {
  id: string;
  label: string; // short label used in sticky nav
  title: string; // pixel-h--lg title shown above content
  accent: "rolo" | "sun" | "leaf" | "moon" | "rolo-deep";
  items: { q: string; aHtml: string }[];
};

const sections: Section[] = [
  {
    id: "basics",
    label: "The basics",
    title: "The basics",
    accent: "rolo",
    items: [
      {
        q: "Is Rolo free?",
        aHtml: `Yes — Project Rolo is completely free and open source. Explore the <a href="${LINKS.repo}" target="_blank" rel="noopener">GitHub Repo</a>.`,
      },
      {
        q: "What operating systems does Rolo support?",
        aHtml: `Project Rolo currently only runs on Mac. The <a href="${LINKS.repo}" target="_blank" rel="noopener">GitHub Repo</a> is open source if you'd like to help expand to Windows and Linux!`,
      },
      {
        q: "Does Rolo send my data anywhere?",
        aHtml: `Nope. All files from chat, memory, and dreams are stored locally on your machine. The one exception is weather — Rolo does a one-time lookup of your approximate location from your IP address, then fetches weather from <a href="https://open-meteo.com/" target="_blank" rel="noopener">Open-Meteo</a> using the coordinates. You can set your location manually or turn weather off entirely in <strong>Rolo's Command Center</strong>.`,
      },
      {
        q: "What files can Rolo eat?",
        aHtml: `Anything and everything. All eaten files go to Trash and are recoverable.`,
      },
      {
        q: "Does Rolo speak other languages?",
        aHtml: `Rolo currently only responds in English. If you'd like Rolo to learn new languages, you can add <a href="https://blog.google/innovation-and-ai/technology/developers-tools/translategemma/" target="_blank" rel="noopener">TranslateGemma</a> to your repo.`,
      },
      {
        q: "Does running Rolo affect my battery life?",
        aHtml: `Coming soon.`,
      },
      {
        q: "Can Rolo launch automatically?",
        aHtml: `Coming soon.`,
      },
      {
        q: "I have multiple monitors — where does Rolo live?",
        aHtml: `Coming soon.`,
      },
    ],
  },
  {
    id: "brain",
    label: "Rolo's brain",
    title: "Setting up Rolo's brain",
    accent: "sun",
    items: [
      {
        q: 'What is a "brain" and why does Rolo need one?',
        aHtml: `Rolo's brain is powered by a language model, which lets him understand your context and respond. The recommended default is the fine-tuned <a href="https://deepmind.google/models/gemma/gemma-3/" target="_blank" rel="noopener">Gemma 3 4B</a> model, hosted via <a href="https://ollama.com/" target="_blank" rel="noopener">Ollama</a> with the trained weights pulled from <a href="https://huggingface.co/" target="_blank" rel="noopener">HuggingFace</a>. The file is ~2&ndash;4&nbsp;GB and only downloads once.`,
      },
      {
        q: "How do I install Rolo’s brain? (non-developer walkthrough)",
        aHtml: `A guided flow is coming soon — install <a href="https://ollama.com/" target="_blank" rel="noopener">Ollama</a>, open Rolo, watch the progress bar, done. No terminal required. Final copy and screenshots are TBC.`,
      },
      {
        q: "Can I use Rolo offline?",
        aHtml: `Yes — once his brain is downloaded, everything runs locally on your machine and doesn't require WiFi.`,
      },
    ],
  },
  {
    id: "byok",
    label: "Your own model",
    title: "Using your own model or API",
    accent: "leaf",
    items: [
      {
        q: "Can I use a different model?",
        aHtml: `Yes. Right-click Rolo &rarr; open <strong>Rolo's Command Center</strong> &rarr; <strong>Brain</strong> tab. Pick a provider (<a href="https://ollama.com/" target="_blank" rel="noopener">Ollama</a>, <a href="https://platform.openai.com/docs/api-reference" target="_blank" rel="noopener">OpenAI-compatible</a>, <a href="https://www.anthropic.com/" target="_blank" rel="noopener">Anthropic</a>, <a href="https://ai.google.dev/gemini-api" target="_blank" rel="noopener">Gemini</a>, <a href="https://huggingface.co/" target="_blank" rel="noopener">Hugging Face</a>, <a href="https://deepinfra.com/" target="_blank" rel="noopener">DeepInfra</a>), paste an API key if needed, hit <strong>Test Connection</strong>, then <strong>Save</strong>.`,
      },
      {
        q: "Are my API keys safe?",
        aHtml: `Yes. Keys are stored locally on your machine and only ever sent to the provider you chose. Rolo doesn't log them anywhere.`,
      },
      {
        q: "Will all features work with a different brain?",
        aHtml: `Most do — but <strong>tool use</strong> (weather, files, time) and <strong>idle speech bubbles</strong> currently only work with <a href="https://ollama.com/" target="_blank" rel="noopener">Ollama</a>. You'll have to do a bit of tinkering in Rolo's codebase after switching brains.`,
      },
    ],
  },
  {
    id: "memory",
    label: "Memory + dreams",
    title: "Memory and dreams",
    accent: "moon",
    items: [
      {
        q: "How does Rolo remember things about me?",
        aHtml: `Rolo remembers in two ways. <strong>First</strong>, anything you directly enter in the <strong>Memory</strong> tab of <strong>Rolo's Command Center</strong> — hit <strong>Save</strong> and Rolo takes a quick nap, dreams, and transfers it into his long-term memory. <strong>Second</strong>, through chat: Rolo stores important details you share (names, events, preferences) and compiles them into memory while he sleeps.`,
      },
      {
        q: "Can I delete what Rolo remembers?",
        aHtml: `Yes. Open <strong>Rolo's Command Center</strong> &rarr; <strong>Memory</strong> tab &rarr; <strong>Clear User Profile</strong> to completely wipe Rolo's memory of you. (He'll be sad about it.)`,
      },
    ],
  },
  {
    id: "troubleshooting",
    label: "Troubleshooting",
    title: "Troubleshooting",
    accent: "rolo-deep",
    items: [
      {
        q: "Why is the Ollama row red?",
        aHtml: `Rolo can't reach his brain. Open the <a href="https://ollama.com/" target="_blank" rel="noopener">Ollama</a> app from Applications (you should see the llama icon in your menu bar), then click <strong>Refresh all</strong> in Rolo's <strong>Perception</strong> tab. If it stays red, your firewall may be blocking it — or switch to a cloud brain in the <strong>Brain</strong> tab.`,
      },
      {
        q: "Why is my weather wrong, or showing the wrong city?",
        aHtml: `Open <strong>Rolo's Command Center</strong> &rarr; <strong>Weather</strong> tab &rarr; turn on <strong>Set my location manually</strong> and enter your coordinates. You can also switch weather providers there.`,
      },
    ],
  },
];
---

<Layout
  title="FAQs — Project Rolo"
  description="Frequently asked questions about Project Rolo — the basics, setting up Rolo's brain, using your own model, memory and dreams, and troubleshooting."
  pageId="faq"
>
  <Header slot="header" />

  {/* ===== HERO ROW ====================================================== */}
  <section class="faq-hero">
    <div class="shell faq-hero__shell">
      <h1 class="pixel-h pixel-h--xl faq-hero__title fade-up d1">
        Frequently Asked Questions<span class="faq-hero__period">.</span>
      </h1>
    </div>
  </section>

  {/* ===== STICKY SECTION NAV ============================================ */}
  {
    /* Editorial index — no buttons, no shadows. Each entry: a colored square
     (section accent), a label, and a small pixel-font count. Active entry
     gets a 2px ink underline. Reads like a table-of-contents, not a toolbar. */
  }
  <nav class="faq-nav" aria-label="Jump to section">
    <div class="shell faq-nav__shell">
      <ul class="faq-nav__list">
        {
          sections.map((s, i) => (
            <li>
              <a
                class:list={[
                  "faq-nav__link",
                  `faq-nav__link--${s.accent}`,
                  i === 0 && "is-active",
                ]}
                href={`#${s.id}`}
                data-nav-pill={s.id}
              >
                <span class="faq-nav__dot" aria-hidden="true" />
                <span class="faq-nav__label">{s.label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </nav>

  {/* ===== FIVE SECTIONS ================================================= */}
  <main class="faq-main">
    <div class="shell">
      {
        sections.map((s) => (
          <section
            class:list={["faq-section", `faq-section--${s.accent}`]}
            id={s.id}
            data-faq-section={s.id}
            aria-labelledby={`${s.id}-title`}
          >
            <header class="faq-section__head">
              <div class="faq-section__title-row fade-up d1">
                <span class="faq-section__tile" aria-hidden="true" />
                <h2
                  id={`${s.id}-title`}
                  class="pixel-h pixel-h--lg faq-section__title"
                >
                  {s.title}
                </h2>
              </div>
              <span class="faq-section__rule fade-up d2" aria-hidden="true" />
            </header>

            <ul class="qa-list" role="list">
              {s.items.map((item) => (
                <li class="qa">
                  <details class="qa__details">
                    <summary class="qa__summary">
                      <span class="qa__q">{item.q}</span>
                      {/* Single rotating pixel chevron — points right when closed,
                        down when open. Calmer than the +/− swap. */}
                      <span class="qa__chev" aria-hidden="true">
                        <svg
                          viewBox="0 0 14 14"
                          width="18"
                          height="18"
                          aria-hidden="true"
                        >
                          <g fill="currentColor" shape-rendering="crispEdges">
                            <rect x="3" y="2" width="2" height="2" />
                            <rect x="5" y="4" width="2" height="2" />
                            <rect x="7" y="6" width="2" height="2" />
                            <rect x="5" y="8" width="2" height="2" />
                            <rect x="3" y="10" width="2" height="2" />
                          </g>
                        </svg>
                      </span>
                    </summary>
                    <div class="qa__answer">
                      <p set:html={item.aHtml} />
                    </div>
                  </details>
                </li>
              ))}
            </ul>
          </section>
        ))
      }

      {/* ===== CLOSING CTA ================================================ */}
      <section class="faq-finale" aria-labelledby="faq-finale-title">
        <div class="faq-finale__panel panel">
          <h2
            id="faq-finale-title"
            class="pixel-h pixel-h--md faq-finale__title"
          >
            Didn&rsquo;t find what you were looking for?
          </h2>
          <div class="faq-finale__ctas">
            <a
              class="btn btn--primary btn--lg faq-finale__cta"
              href={LINKS.repo}
              target="_blank"
              rel="noopener"
            >
              EXPLORE FULL REPO &rarr;
            </a>
            <a
              class="btn btn--ghost btn--lg faq-finale__cta"
              href={LINKS.contact}
            >
              CONTACT US &rarr;
            </a>
          </div>
        </div>
      </section>
    </div>
  </main>

  <Footer slot="footer" />
</Layout>

<style>
  /* =====================================================================
     FAQs — sibling of the homepage. Same paper + ink + dashed rules.
     Every accent on this page is one of the five color tokens; nothing new.
     ===================================================================== */

  /* ===== HERO ROW ====================================================== */
  /* Single-element hero. The sticky nav sits flush below it, bookended by
     ink rules above and below, so the title block reads as a distinct
     chapter opener separated from the index + content beneath it. */
  .faq-hero {
    padding-top: clamp(2.75rem, 6vw, 4.75rem);
    padding-bottom: clamp(1.25rem, 2.5vw, 1.85rem);
  }
  .faq-hero__shell {
    /* Block layout — three-word headline stacks left, no second column */
    display: block;
  }
  .faq-hero__title {
    margin: 0;
    /* Slightly tighter than the homepage hero — this is an index, not a poster.
       Allowed to wrap across multiple lines; the pixel font has presence
       stacked. Tight line-height keeps the stack feeling like one mass. */
    font-size: clamp(2.4rem, 5.4vw, 4rem);
    line-height: 0.95;
    max-width: 14ch;
  }
  /* Pixel typefaces are wide and don't break mid-word; below ~640px the
     longest word ("Frequently") overflows. Drop the floor of the clamp so
     it fits. Visual hierarchy is unaffected — the headline still dominates. */
  @media (max-width: 640px) {
    .faq-hero__title {
      font-size: clamp(1.35rem, 5.6vw, 2.2rem);
    }
  }
  .faq-hero__period {
    color: var(--rolo);
  }

  /* ===== STICKY SECTION NAV ============================================ */
  /* Editorial table-of-contents, not a toolbar. A thin sticky strip under
     the site header. Each entry is a flat link with: 8px color square,
     short label in pixel font, and a tiny count after the label. Active
     entry picks up a 2px ink underline; no boxes, no shadows.            */
  .faq-nav {
    position: sticky;
    top: calc(2.5rem + 52px + 2px);
    z-index: 40;
    background: color-mix(in srgb, var(--bg) 96%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border-top: 1px solid var(--ink);
    border-bottom: 1px solid var(--ink);
    padding: 0.75rem 0;
  }
  @media (max-width: 820px) {
    .faq-nav {
      top: calc(2.2rem + 44px + 2px);
    }
  }
  .faq-nav__shell {
    overflow-x: auto;
    overflow-y: hidden;
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  .faq-nav__shell::-webkit-scrollbar {
    display: none;
  }

  .faq-nav__list {
    display: flex;
    gap: clamp(1rem, 2.5vw, 2rem);
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: nowrap;
    width: max-content;
    min-width: 100%;
    align-items: center;
  }

  /* Link — flat, editorial. No border, no shadow. */
  .faq-nav__link {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.45rem 0;
    font-family: var(--display);
    font-size: 0.55rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--ink-soft);
    background: transparent;
    border: 0;
    text-decoration: none;
    line-height: 1.2;
    white-space: nowrap;
    position: relative;
    transition:
      color 160ms var(--ease-soft),
      transform 160ms var(--ease-soft);
  }
  /* Underline grows from the left on hover/active — magazine TOC feel */
  .faq-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: -2px;
    height: 2px;
    background: currentColor;
    transform: scaleX(0);
    transform-origin: left center;
    transition: transform 220ms var(--ease-soft);
  }
  .faq-nav__link:hover,
  .faq-nav__link:focus-visible {
    color: var(--ink);
    outline: none;
  }
  .faq-nav__link:hover::after,
  .faq-nav__link:focus-visible::after {
    transform: scaleX(0.5);
  }

  .faq-nav__dot {
    width: 9px;
    height: 9px;
    display: inline-block;
    background: currentColor;
    flex-shrink: 0;
    transition: transform 200ms var(--ease-soft);
  }
  .faq-nav__label {
    color: inherit;
  }

  /* Per-section dot colours — the only saturated detail in the nav */
  .faq-nav__link--rolo .faq-nav__dot {
    color: var(--rolo);
  }
  .faq-nav__link--sun .faq-nav__dot {
    color: var(--sun-deep);
  }
  .faq-nav__link--leaf .faq-nav__dot {
    color: var(--leaf-deep);
  }
  .faq-nav__link--moon .faq-nav__dot {
    color: var(--moon-deep);
  }
  .faq-nav__link--rolo-deep .faq-nav__dot {
    color: var(--rolo-deep);
  }

  /* Active state — full ink color, full-width underline, dot scales up */
  .faq-nav__link.is-active {
    color: var(--ink);
  }
  .faq-nav__link.is-active::after {
    transform: scaleX(1);
  }
  .faq-nav__link.is-active .faq-nav__dot {
    transform: scale(1.25);
  }

  /* ===== MAIN ========================================================== */
  .faq-main {
    padding: clamp(2.5rem, 5vw, 4rem) 0 clamp(3rem, 6vw, 5rem);
  }

  /* ===== SECTION ======================================================= */
  .faq-section {
    /* Generous offset so the sticky nav doesn't clip the title when jumped to */
    scroll-margin-top: calc(2.5rem + 52px + 2px + 56px + 1rem);
    padding-top: clamp(2rem, 4vw, 3rem);
    padding-bottom: clamp(1.5rem, 3vw, 2.5rem);
  }
  /* Inter-section divider removed — let space + accent rule carry the break */

  .faq-section__head {
    margin-bottom: clamp(1.25rem, 2.5vw, 1.85rem);
    max-width: 56rem;
  }
  /* Title row — accent tile + section title side-by-side, centered on the
     pixel-font cap-height. Mirrors the sticky-nav dot + label pattern at a
     larger scale. */
  .faq-section__title-row {
    display: flex;
    align-items: center;
    gap: clamp(0.65rem, 1vw, 0.9rem);
  }
  .faq-section__tile {
    display: inline-block;
    width: clamp(0.85rem, 1.4vw, 1.1rem);
    height: clamp(0.85rem, 1.4vw, 1.1rem);
    background: currentColor;
    flex-shrink: 0;
  }
  /* 4px pixel-dashed accent rule beneath the title — runs the full width of
     the accordion below (56rem cap inherited from .faq-section__head). */
  .faq-section__rule {
    display: block;
    width: 100%;
    height: 4px;
    margin-top: clamp(0.85rem, 1.75vw, 1.25rem);
    background: var(--pixel-dash);
  }
  .faq-section--rolo .faq-section__tile,
  .faq-section--rolo .faq-section__rule {
    color: var(--rolo);
  }
  .faq-section--sun .faq-section__tile,
  .faq-section--sun .faq-section__rule {
    color: var(--sun-deep);
  }
  .faq-section--leaf .faq-section__tile,
  .faq-section--leaf .faq-section__rule {
    color: var(--leaf-deep);
  }
  .faq-section--moon .faq-section__tile,
  .faq-section--moon .faq-section__rule {
    color: var(--moon-deep);
  }
  .faq-section--rolo-deep .faq-section__tile,
  .faq-section--rolo-deep .faq-section__rule {
    color: var(--rolo-deep);
  }

  .faq-section__title {
    margin: 0;
  }

  /* ===== ACCORDION ===================================================== */
  .qa-list {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 56rem;
  }
  .qa {
  }
  .qa__details {
  }

  /* Reset default disclosure marker */
  .qa__summary::-webkit-details-marker {
    display: none;
  }
  .qa__summary {
    list-style: none;
  }

  /* Summary row — dashed bottom rule echoes the homepage checklist rhythm.
     Grid: question text left, pixel chevron right, both anchored to the
     same baseline. */
  /* Summary row — two-column grid: question text and a single rotating
     chevron. Stable padding; the hover background is a subtle wash, no
     margin tricks. */
  .qa__summary {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1.25rem;
    padding: 1rem 0;
    border-bottom: 1px dashed var(--rule);
    cursor: pointer;
    position: relative;
    transition: color 160ms var(--ease-soft);
  }
  /* Background lift via ::before so the wash can bleed past the text
     without shifting layout. Sits underneath text + chevron. */
  .qa__summary::before {
    content: "";
    position: absolute;
    inset: 0 -0.75rem;
    background: transparent;
    transition: background 200ms var(--ease-soft);
    z-index: -1;
  }
  .qa:first-child .qa__summary {
    padding-top: 0.5rem;
  }
  .qa:last-child .qa__summary {
    border-bottom: 1px dashed var(--rule);
  }

  .qa__summary:hover::before {
    background: var(--paper);
  }
  .qa__summary:hover .qa__q {
    color: var(--rolo-deep);
  }

  .qa__summary:focus-visible {
    outline: 3px solid var(--rolo);
    outline-offset: 4px;
  }

  .qa__q {
    font-family: var(--body);
    font-weight: 500;
    font-size: clamp(1.02rem, 0.4vw + 0.9rem, 1.18rem);
    line-height: 1.45;
    color: var(--ink);
    letter-spacing: -0.005em;
    transition: color 160ms var(--ease-soft);
  }

  /* Single pixel chevron — rotates 90° clockwise when open. Color picks up
     the section accent when the row is opened. */
  .qa__chev {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    flex-shrink: 0;
    color: var(--ink-soft);
    transition:
      color 200ms var(--ease-soft),
      transform 260ms var(--ease-soft);
  }
  .qa__summary:hover .qa__chev {
    color: var(--rolo-deep);
    transform: translateX(2px);
  }
  .qa__details[open] > .qa__summary .qa__chev {
    transform: rotate(90deg);
  }
  .qa__details[open] > .qa__summary:hover .qa__chev {
    transform: rotate(90deg) translateX(2px);
  }

  /* Per-section accent on open chevron */
  .faq-section--rolo .qa__details[open] > .qa__summary .qa__chev {
    color: var(--rolo);
  }
  .faq-section--sun .qa__details[open] > .qa__summary .qa__chev {
    color: var(--sun-deep);
  }
  .faq-section--leaf .qa__details[open] > .qa__summary .qa__chev {
    color: var(--leaf-deep);
  }
  .faq-section--moon .qa__details[open] > .qa__summary .qa__chev {
    color: var(--moon-deep);
  }
  .faq-section--rolo-deep .qa__details[open] > .qa__summary .qa__chev {
    color: var(--rolo-deep);
  }

  /* Answer — aligned to the question's left edge. No border, no background;
     the rotating accent-coloured chevron and the visible answer body carry
     the open state. Generous top padding so the answer reads as a distinct
     block from the question above. */
  .qa__answer {
    margin-left: 0;
    padding: 0.9rem 0 1.5rem;
    animation: qa-reveal 280ms var(--ease-soft);
  }
  @keyframes qa-reveal {
    from {
      opacity: 0;
      transform: translateY(-3px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 640px) {
    .qa__summary {
      grid-template-columns: 1fr auto;
      gap: 0.85rem;
    }
    .qa__answer {
      margin-left: 0;
    }
  }

  .qa__answer p {
    font-family: var(--body);
    font-size: 1rem;
    line-height: 1.65;
    color: var(--ink);
    margin: 0;
  }
  .qa__answer :global(strong) {
    font-weight: 700;
    color: var(--ink);
  }
  .qa__answer :global(a) {
    color: var(--rolo-deep);
    font-weight: 600;
  }

  /* ===== CLOSING CTA =================================================== */
  .faq-finale {
    margin-top: clamp(3.5rem, 7vw, 5rem);
    display: flex;
    justify-content: center;
  }
  .faq-finale__panel {
    text-align: center;
    max-width: 38rem;
    width: 100%;
    padding: clamp(2.25rem, 4.5vw, 3rem) clamp(1.5rem, 4vw, 3rem);
    position: relative;
  }
  .faq-finale__title {
    margin: 0 auto 1.75rem;
    max-width: 24ch;
  }
  .faq-finale__ctas {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: clamp(0.75rem, 1.5vw, 1rem);
  }
  .faq-finale__cta {
    /* No extra rules — inherits .btn vocabulary */
  }

  /* ===== MOTION-SAFE OVERRIDES ========================================= */
  @media (prefers-reduced-motion: reduce) {
    .qa__answer {
      animation: none;
    }
  }
</style>

<script>
  // =====================================================================
  // Sticky section-nav active state. IntersectionObserver watches the five
  // sections; the topmost-anchored one in view wins. Falls back gracefully
  // — if the observer never fires, plain anchor jumps still work.
  // =====================================================================
  (function initFaqNav() {
    const pills = Array.from(
      document.querySelectorAll<HTMLAnchorElement>("[data-nav-pill]"),
    );
    const sections = Array.from(
      document.querySelectorAll<HTMLElement>("[data-faq-section]"),
    );
    if (!pills.length || !sections.length) return;

    const pillById = new Map<string, HTMLAnchorElement>();
    pills.forEach((p) => {
      const id = p.dataset.navPill;
      if (id) pillById.set(id, p);
    });

    function setActive(id: string) {
      pills.forEach((p) =>
        p.classList.toggle("is-active", p.dataset.navPill === id),
      );
    }

    // Track which sections are currently intersecting; pick the topmost
    // one (smallest boundingClientRect.top that's still >= 0, else the
    // largest negative — i.e. the one whose top is closest to the
    // viewport top from above).
    const visible = new Set<string>();
    const io = new IntersectionObserver(
      (entries) => {
        entries.forEach((e) => {
          const id = (e.target as HTMLElement).dataset.faqSection;
          if (!id) return;
          if (e.isIntersecting) visible.add(id);
          else visible.delete(id);
        });

        if (visible.size === 0) return;

        // Order sections by document order, then pick the topmost visible
        let chosen: string | null = null;
        for (const s of sections) {
          const id = s.dataset.faqSection;
          if (id && visible.has(id)) {
            chosen = id;
            break;
          }
        }
        if (chosen) setActive(chosen);
      },
      {
        // Bias the "in view" window so a section counts as active just
        // before its title hits the sticky nav. Top margin matches the
        // nav stack roughly; bottom margin keeps a section active until
        // the next one is well into the viewport.
        rootMargin: "-180px 0px -55% 0px",
        threshold: 0,
      },
    );
    sections.forEach((s) => io.observe(s));

    // Click should immediately reflect — IntersectionObserver fires async.
    pills.forEach((p) => {
      p.addEventListener("click", () => {
        const id = p.dataset.navPill;
        if (id) setActive(id);
      });
    });
  })();
</script>
