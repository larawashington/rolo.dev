---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RoloSprite from '../components/RoloSprite.astro';

const faqs = [
  {
    q: 'is rolo really free?',
    a: 'Yes. Rolo is free to download and open source. No accounts, no subscriptions, no ads, no telemetry. He lives entirely on your machine.',
  },
  {
    q: 'what platforms does he run on?',
    a: 'macOS, Windows, and Linux. He’s built with Tauri, which gives him a tiny footprint on every platform.',
  },
  {
    q: 'will he get in the way of my work?',
    a: 'Rolo is designed to stay out of the way. He wanders quietly, can be tucked into a corner, and ignores clicks meant for other windows. He won’t notify, interrupt, or steal focus.',
  },
  {
    q: 'what happens to files i feed him?',
    a: 'Nothing destructive — Rolo just acknowledges them with an animation. He doesn’t move, delete, upload, or modify files. (Full details once we ship.)',
  },
  {
    q: 'can i help build rolo?',
    a: 'Absolutely. The source lives on GitHub. Feel free to file issues, open PRs, or just lurk and watch. He’s a small project with room to grow.',
  },
] as const;
---
<Layout title="FAQ — Rolo" description="Frequently asked questions about Rolo, the cosy desktop pet." pageId="faq">
  <Header slot="header" />

  <section class="stub-hero">
    <div class="shell stub-hero__inner">
      <div class="stub-hero__copy">
        <p class="eyebrow">help &amp; questions</p>
        <h1 class="stub-hero__title">frequently<br/><span class="t-sage">asked.</span></h1>
        <p class="lede">
          A small collection of answers. If something here doesn&rsquo;t cover your
          question, <a href="contact">say hello</a> &mdash; we&rsquo;d love to hear from you.
        </p>
      </div>
      <div class="stub-hero__rolo">
        <RoloSprite size={180} />
      </div>
    </div>
  </section>

  <section class="section">
    <div class="shell">
      <ul class="faq-list">
        {faqs.map((item, i) => (
          <li class="faq-item fade-up" style={`animation-delay:${i * 80}ms`}>
            <details>
              <summary>
                <span class="faq-q">{item.q}</span>
                <span class="faq-marker" aria-hidden="true">+</span>
              </summary>
              <div class="faq-a">{item.a}</div>
            </details>
          </li>
        ))}
      </ul>

      <p class="stub-note">
        <span class="hero__pill">placeholder</span>
        More questions and answers will land here as Rolo gets closer to launch.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .stub-hero {
    padding: clamp(2rem, 6vw, 4rem) 0 clamp(1rem, 3vw, 2rem);
  }
  .stub-hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 2rem;
  }
  .stub-hero__title {
    font-family: 'Silkscreen', monospace;
    font-size: clamp(2.4rem, 5vw, 4.2rem);
    line-height: 1;
    color: var(--navy);
    margin-bottom: 1rem;
  }
  .t-sage { color: var(--sage-deep); }
  @media (max-width: 720px) {
    .stub-hero__inner { grid-template-columns: 1fr; }
    .stub-hero__rolo { justify-self: end; }
  }

  .faq-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    max-width: 56rem;
  }
  .faq-item {
    background: var(--bg-tint);
    border: 2px solid var(--navy);
    box-shadow: var(--shadow-pixel-sm);
    transition: box-shadow 200ms var(--ease-soft), transform 200ms var(--ease-soft);
    opacity: 0;
  }
  .faq-item:hover {
    box-shadow: var(--shadow-pixel);
    transform: translate(-2px, -2px);
  }
  details > summary {
    list-style: none;
    cursor: pointer;
    padding: 1rem 1.25rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  details > summary::-webkit-details-marker { display: none; }
  .faq-q {
    font-family: 'Silkscreen', monospace;
    font-size: 1.05rem;
    color: var(--navy);
    letter-spacing: 0.01em;
    line-height: 1.3;
  }
  .faq-marker {
    font-family: 'VT323', monospace;
    font-size: 1.6rem;
    color: var(--sage-deep);
    transition: transform 200ms var(--ease-soft);
  }
  details[open] .faq-marker { transform: rotate(45deg); }
  .faq-a {
    padding: 0 1.25rem 1.25rem;
    color: var(--text-soft);
    font-size: 1rem;
    line-height: 1.65;
    border-top: 2px dashed var(--surface-2);
    padding-top: 1rem;
  }

  .stub-note {
    margin-top: 3rem;
    padding: 1rem 1.25rem;
    background: var(--surface);
    border: 2px dashed var(--navy-soft);
    color: var(--navy-soft);
    font-family: 'VT323', monospace;
    font-size: 1.15rem;
    letter-spacing: 0.04em;
    display: flex;
    gap: 0.85rem;
    align-items: center;
    max-width: 56rem;
  }
</style>
