---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { LINKS } from '../lib/links';

const sections = [
  { id: 'sft', title: 'Supervised Fine-Tune of Gemma 3 4B Model' },
  { id: 'dyna-q', title: 'Dyna-Q Reinforcement Learning' },
  { id: 'tools', title: 'Tool Calls + Perception' },
];
---
<Layout title="Tech + Process — Project Rolo" pageId="tech">
  <Header slot="header" />

  <section class="section section--stub">
    <div class="shell">
      <p class="eyebrow">behind the curtain &nbsp;//&nbsp; ch.??</p>
      <h1 class="pixel-h pixel-h--xl stub__title">Tech + Process</h1>

      <p class="lede stub__intro">
        A detailed documentation page of Rolo&rsquo;s system architecture and reasoning for decision-making.
        Lorem ipsum dolor sit amet, consectetur adipiscing elit.
      </p>

      {sections.map((s, i) => (
        <article class="stub__block panel" id={s.id}>
          <span class="stub__num" aria-hidden="true">0{i + 1}</span>
          <h2 class="pixel-h pixel-h--md stub__block-title">{s.title}</h2>
          <p>
            Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed
            do eiusmod tempor incididunt ut labore et dolore magna aliqua.
            Ut enim ad minim veniam, quis nostrud exercitation ullamco
            laboris nisi ut aliquip ex ea commodo consequat.
          </p>
        </article>
      ))}

      <div class="stub__cta">
        {/* PLACEHOLDER: repo */}
        <a class="btn btn--primary btn--lg" href={LINKS.repo} target="_blank" rel="noopener">
          Explore the full GitHub Repo &rarr;
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .section--stub { padding-top: clamp(3rem, 6vw, 5rem); }
  .stub__title { margin: 1.25rem 0 1.5rem; }
  .stub__intro { margin-bottom: 2.5rem; }

  .stub__block {
    position: relative;
    margin-bottom: 1.5rem;
    padding-top: 2.25rem;
  }
  .stub__num {
    position: absolute;
    top: -14px; left: 20px;
    font-family: var(--display);
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    color: var(--rolo);
    background: var(--paper);
    border: 2px solid var(--ink);
    padding: 0.35rem 0.6rem;
  }
  .stub__block-title {
    margin-bottom: 0.85rem;
    color: var(--ink);
  }

  .stub__cta {
    margin-top: 2.5rem;
    text-align: center;
  }
</style>
