---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { LINKS } from '../lib/links';
---
<Layout title="Contact — Project Rolo" pageId="contact">
  <Header slot="header" />

  <section class="section section--stub">
    <div class="shell">
      <h1 class="pixel-h pixel-h--xl stub__title">Contact</h1>

      <div class="stub__panel panel">
        <p class="stub__placeholder">A proper form is on the way.</p>
        <p>
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. In the
          meantime, the easiest way to reach us is below.
        </p>
        <ul class="stub__list">
          <li>
            {/* PLACEHOLDER: email */}
            <span class="stub__key">Email</span>
            <a href={LINKS.email}>tbc</a>
          </li>
          <li>
            <span class="stub__key">GitHub</span>
            <a href={LINKS.github} target="_blank" rel="noopener">larawashington</a>
          </li>
          <li>
            <span class="stub__key">LinkedIn</span>
            <a href={LINKS.linkedin} target="_blank" rel="noopener">lara-washington</a>
          </li>
        </ul>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .section--stub { padding-top: clamp(3rem, 6vw, 5rem); }
  .stub__title { margin: 1.25rem 0 2rem; }
  .stub__panel { max-width: 56rem; }
  .stub__placeholder {
    font-family: var(--display);
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    color: var(--rolo-deep);
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  .stub__list {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0 0;
    display: grid;
    gap: 0.6rem;
  }
  .stub__list li {
    display: grid;
    grid-template-columns: 7rem 1fr;
    gap: 1rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px dashed var(--rule);
    font-size: 1rem;
  }
  .stub__key {
    font-family: var(--display);
    font-size: 0.6rem;
    letter-spacing: 0.14em;
    color: var(--ink-soft);
    text-transform: uppercase;
    padding-top: 4px;
  }
</style>
