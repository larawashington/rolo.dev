---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WindowFrame from '../components/WindowFrame.astro';
import { LINKS } from '../lib/links';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';

// Section 3 — carousel slides (exact copy from wireframe).
// `accent` colours the WindowFrame chrome per-slide.
const slides = [
  {
    id: 'roaming',
    title: 'Roaming',
    src: `${base}gifs/rolo_walk_right.gif`,
    copy: 'Rolo walks across your screen and sees what you see. He will occasionally comment on your work and cheer you on.',
    alt: 'Rolo walking to the right',
    accent: 'rolo' as const,
  },
  {
    id: 'eating',
    title: 'Eating',
    src: `${base}gifs/rolo_eat.gif`,
    copy: 'Rolo is happiest when you’re happy, and second happiest when he gets to eat! Drag and drop files onto Rolo to feed him (eaten files go to Trash).',
    alt: 'Rolo munching on something',
    accent: 'leaf' as const,
  },
  {
    id: 'chatting',
    title: 'Chatting',
    src: `${base}gifs/rolo_waiting.gif`,
    copy: 'Rolo loves to chat. Take a break and chat with Rolo about anything you like. As he learns more about you, he will remember important details you share for the future. Ask him about the weather!',
    alt: 'Rolo waiting patiently, ready for a chat',
    accent: 'sun' as const,
  },
  {
    id: 'sleeping',
    title: 'Sleeping',
    src: `${base}gifs/Rolo_sleep.gif`,
    copy: 'Rolo takes naps and dreams. Like us humans, this is when he processes and transfers information into his memory.',
    alt: 'Rolo curled up, asleep',
    accent: 'moon' as const,
  },
];

// Section 2 — checklist items (exact copy from wireframe; first two = check, third = cross)
const checklist = [
  {
    kind: 'ok' as const,
    text: 'Rolo lives on your screen and keeps you company throughout everyday tasks. He acts as a positive counterbalance to our internal dialogues and anxieties.',
  },
  {
    kind: 'ok' as const,
    text: 'Rolo’s primary concern is your wellbeing and will do his best to bring out your best self. His secondary concern may be food-related. More on this later…',
  },
  {
    kind: 'no' as const,
    text: 'Rolo is NOT an AI assistant or tool. Do not confuse him with one (he will take offense). He will decline any requests that contradict his character and purpose of bringing joy and whimsy to your screen.',
  },
];
---
<Layout
  title="Project Rolo — a free, open-source desktop companion"
  description="Meet Rolo. A free, open-source desktop companion here to make your day a little brighter."
  pageId="home"
>
  <Header slot="header" />

  {/* ===== SECTION 1 — HERO ============================================== */}
  <section class="hero">
    <div class="shell hero__shell">

      <div class="hero__copy">
        <h1 class="pixel-h pixel-h--xl hero__title fade-up d1">
          Meet<br/><span class="hero__title-accent">Rolo<span class="hero__title-period">.</span></span>
        </h1>

        <p class="lede hero__lede fade-up d2">
          A free, open-source desktop companion here to make your day
          a little brighter.
        </p>

        <div class="hero__cta fade-up d3" role="group" aria-label="Get Rolo">
          {/* PLACEHOLDER: downloadMac — see src/lib/links.ts */}
          <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
            DOWNLOAD ROLO
            <span class="hero__cta-meta">(MAC)</span>
          </a>
          {/* PLACEHOLDER: repo */}
          <a class="btn btn--ghost btn--lg" href={LINKS.repo} target="_blank" rel="noopener">
            EXPLORE THE REPO &rarr;
          </a>
        </div>
      </div>

      <div class="hero__stage fade-up d2">
        <img
          class="hero__rolo pixel"
          src={`${base}gifs/Rolo_idle.gif`}
          alt="Rolo, idle — a small pixel-art creature in a pointed red hood"
          width="520"
          height="520"
        />
        <div class="hero__ground" aria-hidden="true"></div>
      </div>

    </div>
  </section>

  {/* ===== SECTION 2 — WHAT DOES ROLO DO? ================================ */}
  <section class="section section--what">
    <div class="shell">
      <header class="what__head">
        <h2 class="pixel-h pixel-h--lg what__title fade-up d1">
          What does Rolo do?
        </h2>
      </header>

      <ul class="checklist">
        {checklist.map((item, i) => (
          <li class:list={['check', `check--${item.kind}`, 'fade-up']} style={`animation-delay:${(i + 1) * 110}ms`}>
            <span class="check__mark" aria-hidden="true">
              {item.kind === 'ok' ? (
                /* Pixel-style check — built from absolutely-positioned blocks
                   so it reads as hand-pixelled, not as a vector tick. */
                <svg viewBox="0 0 14 14" width="40" height="40" aria-hidden="true">
                  <g fill="currentColor" shape-rendering="crispEdges">
                    <rect x="1" y="6" width="2" height="2"/>
                    <rect x="3" y="8" width="2" height="2"/>
                    <rect x="5" y="10" width="2" height="2"/>
                    <rect x="7" y="8" width="2" height="2"/>
                    <rect x="9" y="6" width="2" height="2"/>
                    <rect x="11" y="4" width="2" height="2"/>
                  </g>
                </svg>
              ) : (
                /* Symmetric pixel X: two diagonals on a 7x7 lattice
                   (2x2 px blocks inside a 14x14 viewBox), crossing at centre. */
                <svg viewBox="0 0 14 14" width="28" height="28" aria-hidden="true">
                  <g fill="currentColor" shape-rendering="crispEdges">
                    {/* top-left → bottom-right diagonal */}
                    <rect x="0"  y="0"  width="2" height="2"/>
                    <rect x="2"  y="2"  width="2" height="2"/>
                    <rect x="4"  y="4"  width="2" height="2"/>
                    <rect x="6"  y="6"  width="2" height="2"/>
                    <rect x="8"  y="8"  width="2" height="2"/>
                    <rect x="10" y="10" width="2" height="2"/>
                    <rect x="12" y="12" width="2" height="2"/>
                    {/* top-right → bottom-left diagonal */}
                    <rect x="12" y="0"  width="2" height="2"/>
                    <rect x="10" y="2"  width="2" height="2"/>
                    <rect x="8"  y="4"  width="2" height="2"/>
                    <rect x="4"  y="8"  width="2" height="2"/>
                    <rect x="2"  y="10" width="2" height="2"/>
                    <rect x="0"  y="12" width="2" height="2"/>
                  </g>
                </svg>
              )}
            </span>
            <p class="check__text">{item.text}</p>
          </li>
        ))}
      </ul>

      <div class="what__cta">
        {/* PLACEHOLDER: downloadMac */}
        <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
          DOWNLOAD ROLO TO YOUR DESKTOP
        </a>
      </div>
    </div>
  </section>

  {/* ===== SECTION 3 — A DAY IN THE LIFE (CAROUSEL) ====================== */}
  <section class="section section--day" id="day">
    <div class="shell">
      <header class="day__head">
        <h2 class="pixel-h pixel-h--lg day__title fade-up d1">
          A day in the life of Rolo:
        </h2>
      </header>

      <div
        class="carousel"
        role="region"
        aria-roledescription="carousel"
        aria-label="Rolo's daily activities"
        tabindex="0"
        data-carousel
        data-count={slides.length}
      >
        <button
          class="carousel__arrow carousel__arrow--prev"
          type="button"
          aria-label="previous"
          data-prev
        >
          <svg viewBox="0 0 12 12" width="22" height="22" aria-hidden="true">
            <g fill="currentColor" shape-rendering="crispEdges">
              <rect x="7" y="2" width="2" height="2"/>
              <rect x="5" y="4" width="2" height="2"/>
              <rect x="3" y="5" width="2" height="2"/>
              <rect x="5" y="6" width="2" height="2"/>
              <rect x="7" y="8" width="2" height="2"/>
            </g>
          </svg>
        </button>

        <div class="carousel__track" data-track>
          {slides.map((s, i) => (
            <article
              class="carousel__slide"
              data-slide
              data-index={i}
              aria-label={`Slide ${i + 1} of ${slides.length}: ${s.title}`}
            >
              <WindowFrame title={s.title} accent={s.accent} class="day__window">
                <div class="slide-stage">
                  <img
                    class="slide-stage__img pixel"
                    src={s.src}
                    alt={s.alt}
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                </div>
                <div class="slide-body">
                  <p class="slide-body__copy">{s.copy}</p>
                </div>
              </WindowFrame>
            </article>
          ))}
        </div>

        <button
          class="carousel__arrow carousel__arrow--next"
          type="button"
          aria-label="next"
          data-next
        >
          <svg viewBox="0 0 12 12" width="22" height="22" aria-hidden="true">
            <g fill="currentColor" shape-rendering="crispEdges">
              <rect x="3" y="2" width="2" height="2"/>
              <rect x="5" y="4" width="2" height="2"/>
              <rect x="7" y="5" width="2" height="2"/>
              <rect x="5" y="6" width="2" height="2"/>
              <rect x="3" y="8" width="2" height="2"/>
            </g>
          </svg>
        </button>
      </div>

      <div class="carousel__dots" aria-hidden="true" data-dots>
        {slides.map((_, i) => (
          <span class:list={['carousel__dot', i === 0 && 'is-active']} data-dot={i}></span>
        ))}
      </div>

      <div class="day__cta">
        {/* PLACEHOLDER: downloadMac */}
        <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
          BRING ROLO TO LIFE
        </a>
      </div>
    </div>
  </section>

  {/* ===== SECTION 4 — HOW DOES ROLO FUNCTION? =========================== */}
  <section class="section section--how">
    <div class="shell">
      <header class="how__head">
        <h2 class="pixel-h pixel-h--lg how__title fade-up d1">
          How does Rolo function?
        </h2>
        <p class="lede how__lede fade-up d2">
          Rolo lives locally on your machine and respects your privacy. He is powered by 3 pillars:
        </p>
      </header>

      <figure class="diagram fade-up d2">
        <img
          class="diagram__img pixel"
          src={`${base}rolo-how-it-works.png`}
          alt="Diagram of how Rolo works: three boxes hanging off Rolo — his Voice (a fine-tuned Gemma 3 4B model), his Status (mood from hunger, social and energy levels plus on-screen activity), and his Memory (the Vault, compiled when he dreams)."
          loading="lazy"
        />
      </figure>

      <ol class="pillars">
        <li class="pillar pillar--voice fade-up d1">
          <span class="pillar__chip" aria-hidden="true"></span>
          <h3 class="pillar__title">Rolo&rsquo;s voice</h3>
          <p class="pillar__body">
            comes from a fine-tuned
            <a href="https://deepmind.google/models/gemma/gemma-3/" target="_blank" rel="noopener">Gemma 3 4B</a>
            model. A small open-source large-language model trained on hand-seeded examples of how Rolo speaks.
          </p>
        </li>
        <li class="pillar pillar--status fade-up d2">
          <span class="pillar__chip" aria-hidden="true"></span>
          <h3 class="pillar__title">Rolo&rsquo;s status</h3>
          <p class="pillar__body">
            is hardcoded and his mood depends on his hunger, social, energy, and happiness levels.
            This is combined with his perception of the activity on your screen to add flavor and relevance to his speech.
          </p>
        </li>
        <li class="pillar pillar--memory fade-up d3">
          <span class="pillar__chip" aria-hidden="true"></span>
          <h3 class="pillar__title">Rolo&rsquo;s memory</h3>
          <p class="pillar__body">
            is built through ongoing interactions with you. He remembers key information you share
            (names, events, preferences) and stores this into his memory while he sleeps and dreams.
          </p>
        </li>
      </ol>

      <div class="how__footer">
        <p class="how__more">
          To learn more about the system architecture of Rolo&rsquo;s soul,<br/>
          head to the <a href={LINKS.techProcess}>Tech + Process</a> page.
        </p>
        <a class="btn btn--ghost" href={LINKS.techProcess}>
          READ THE DEEP DIVE &rarr;
        </a>
      </div>
    </div>
  </section>

  {/* ===== SECTION 5 — READY TO MEET ROLO? ============================== */}
  <section class="section section--finale" aria-labelledby="finale-title">
    <div class="shell">
      <header class="finale__head">
        <h2 id="finale-title" class="pixel-h pixel-h--lg finale__title fade-up d1">
          Ready to meet <span class="finale__title-rolo">Rolo</span>?
        </h2>
      </header>

      <div class="finale__stage fade-up d2">
        {/* Idle by default; swaps to happy on hover. The whole sprite is a
            download trigger — same destination as the CTA below. */}
        <a class="finale__rolo-swap" href={LINKS.downloadMac} aria-label="Download Rolo">
          <img
            class="finale__rolo finale__rolo--idle pixel"
            src={`${base}rolo-idle.png`}
            alt="Rolo, idle — a small pixel-art creature in a pointed red hood"
            loading="lazy"
          />
          <img
            class="finale__rolo finale__rolo--happy pixel"
            src={`${base}rolo-happy.png`}
            alt=""
            aria-hidden="true"
            loading="lazy"
          />
        </a>
        <div class="finale__ground" aria-hidden="true"></div>
      </div>

      <div class="finale__cta fade-up d3">
        {/* PLACEHOLDER: downloadMac — see src/lib/links.ts */}
        <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
          DOWNLOAD NOW
        </a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ===== HERO ============================================================ */
  .hero {
    padding-top: clamp(2.5rem, 6vw, 5rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    position: relative;
  }
  .hero__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
    min-height: clamp(520px, 74vh, 720px);
  }
  @media (max-width: 900px) {
    .hero__shell {
      grid-template-columns: 1fr;
      align-items: stretch;
      min-height: unset;
      gap: 2rem;
    }
  }

  .hero__copy { max-width: 34rem; position: relative; z-index: 3; }
  .hero__title {
    margin: 1.25rem 0 1.5rem;
    /* +30% then +20% over global pixel-h--xl — hero headline jumps off the page */
    font-size: clamp(2.73rem, 6.55vw, 5.3rem);
  }
  .hero__title-accent {
    color: var(--rolo);
    position: relative;
    display: inline-block;
  }
  .hero__title-period { color: var(--ink); }
  .hero__title-accent::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -10px;
    height: 4px;
    color: var(--ink); /* dash color (currentColor in the recipe) */
    background: var(--pixel-dash);
  }
  .hero__lede { margin-bottom: 2.25rem; max-width: 34ch; }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }
  .hero__cta-meta {
    font-family: var(--display);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    opacity: 0.85;
    margin-left: 0.35rem;
  }

  /* Stage — Rolo on a ground line, breaking the grid */
  .hero__stage {
    position: relative;
    align-self: center;
    justify-self: center;
    width: 100%;
    display: grid;
    place-items: end center;
    padding-bottom: 2rem;
  }
  .hero__rolo {
    position: relative;
    z-index: 2;
    width: clamp(280px, 36vw, 520px);
    height: auto;
    /* hard pixel shadow + soft ambient — printmaking feel */
    filter: drop-shadow(0 14px 0 rgba(42, 24, 16, 0.10))
            drop-shadow(0 24px 28px rgba(232, 101, 74, 0.22));
    transform-origin: bottom center;
  }
  .hero__ground {
    width: min(86%, 460px);
    height: 4px;
    color: var(--ink); /* dash color (currentColor in the recipe) */
    background: var(--pixel-dash-tight);
    margin-top: 0.5rem;
  }

  /* ===== SECTION 2 — WHAT ================================================ */
  .section--what {
    background: var(--paper);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }
  .what__head { margin-bottom: clamp(2rem, 4vw, 3rem); max-width: 48rem; }
  .what__title { margin-top: 1.25rem; }

  /* Editorial list — no cards, no borders, no shadows. Pixel marks sit
     in the margin like printer's bullets; thin dashed rules give rhythm.
     The CTA below becomes the only bordered surface in the section,
     reading as the unmistakable climax. */
  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    max-width: 62rem;
  }
  .check {
    display: grid;
    grid-template-columns: 56px 1fr;
    gap: 1.5rem;
    align-items: start;
    padding: 1.75rem 0;
    border-bottom: 1px dashed var(--rule);
  }
  .check:first-child { padding-top: 0.5rem; }
  .check:last-child  { border-bottom: 0; }
  .check__mark {
    display: inline-flex;
    align-items: flex-start;
    justify-content: center;
    line-height: 0;
  }
  .check--ok .check__mark { color: var(--ok); }
  .check--no .check__mark { color: var(--no); }
  .check__text {
    font-family: var(--body);
    font-size: clamp(1.05rem, 0.5vw + 0.9rem, 1.18rem);
    line-height: 1.65;
    color: var(--ink);
    margin: 0;
    max-width: 60ch;
  }

  /* CTA sits in its own breathing room, centered for ceremony.
     It's the only chunky-bordered object in the section — the climax. */
  .what__cta {
    margin-top: clamp(3rem, 6vw, 4.5rem);
    text-align: center;
  }

  /* ===== SECTION 3 — CAROUSEL ============================================ */
  .section--day {
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .day__head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .day__title {
    margin-top: 1.25rem;
    white-space: nowrap;
  }
  /* Allow wrap on narrow viewports where nowrap would overflow */
  @media (max-width: 560px) {
    .day__title { white-space: normal; }
  }

  /* Carousel uses peek/active state machine: active slide centered at full
     scale, prev/next peek slides tilted on either side at lower opacity.
     Slides absolute-positioned in a fixed-height track. */
  .carousel {
    position: relative;
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: 1rem;
    padding: 1rem 0 0.5rem;
  }
  .carousel:focus-visible { outline: 3px solid var(--rolo); outline-offset: 8px; }

  .carousel__track {
    position: relative;
    overflow: visible;
    height: clamp(460px, 58vw, 600px);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel__slide {
    position: absolute;
    top: 0;
    left: 50%;
    width: min(540px, 92%);
    height: 100%;
    transform: translateX(-50%) scale(0.86);
    opacity: 0;
    pointer-events: none;
    transition:
      transform 480ms var(--ease-soft),
      opacity 380ms var(--ease-soft);
    will-change: transform, opacity;
  }
  .carousel__slide.is-active {
    opacity: 1;
    transform: translateX(-50%) scale(1);
    pointer-events: auto;
    z-index: 3;
  }
  .carousel__slide.is-prev {
    opacity: 0.45;
    transform: translateX(calc(-50% - 56%)) scale(0.78) rotate(-2deg);
    z-index: 2;
    cursor: pointer;
  }
  .carousel__slide.is-next {
    opacity: 0.45;
    transform: translateX(calc(-50% + 56%)) scale(0.78) rotate(2deg);
    z-index: 2;
    cursor: pointer;
  }

  :global(.day__window) {
    height: 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
  }
  :global(.day__window .window__body) {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  /* Media stage inside the window — solid paper so the gif pops without
     fighting the body's pixel-dot texture. Hard ink rule separates it
     from the copy block below. */
  .slide-stage {
    flex: 1;
    background: var(--bg);
    background-image: none;
    border-bottom: 2px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 2.5vw, 1.75rem);
    min-height: clamp(280px, 36vw, 380px);
  }
  /* Gif scales to fill the stage — pixel-art so up-scaling stays crisp. */
  .slide-stage__img {
    width: 100%;
    height: 100%;
    max-height: 100%;
    object-fit: contain;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    filter: drop-shadow(0 6px 0 rgba(42, 24, 16, 0.10));
  }

  .slide-body {
    background: var(--paper);
    padding: 1.25rem 1.4rem 1.4rem;
  }
  .slide-body__copy {
    font-family: var(--body);
    font-size: clamp(0.95rem, 0.4vw + 0.85rem, 1.05rem);
    line-height: 1.55;
    color: var(--ink);
    max-width: 52ch;
    margin: 0;
  }

  /* Arrows — pixel-style chunky bordered buttons, v1 hover vocabulary */
  .carousel__arrow {
    position: relative;
    width: 48px; height: 48px;
    background: var(--paper);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-pixel-sm);
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    transition: transform 140ms var(--ease-soft),
                box-shadow 140ms var(--ease-soft),
                background 160ms var(--ease-soft),
                color 160ms var(--ease-soft),
                opacity 160ms var(--ease-soft);
  }
  .carousel__arrow:hover {
    transform: translate(-2px, -2px);
    background: var(--rolo);
    color: var(--paper);
    box-shadow: 6px 6px 0 var(--ink);
  }
  .carousel__arrow:active {
    transform: translate(2px, 2px);
    box-shadow: var(--shadow-pixel-press);
  }
  .carousel__arrow[disabled] {
    opacity: 0.35;
    pointer-events: none;
  }

  @media (max-width: 720px) {
    .carousel { grid-template-columns: 1fr; }
    .carousel__arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      z-index: 6;
    }
    .carousel__arrow:hover {
      transform: translate(-2px, calc(-50% - 2px));
    }
    .carousel__arrow:active {
      transform: translate(2px, calc(-50% + 2px));
    }
    .carousel__arrow--prev { left: -4px; }
    .carousel__arrow--next { right: -4px; }
    .carousel__slide.is-prev,
    .carousel__slide.is-next { opacity: 0; }
  }

  /* Dots — progress indicator */
  .carousel__dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin: 1.25rem 0 0;
  }
  .carousel__dot {
    width: 10px; height: 10px;
    background: var(--paper);
    border: 2px solid var(--ink);
    cursor: pointer;
    transition: background 160ms var(--ease-soft), transform 160ms var(--ease-soft);
  }
  .carousel__dot.is-active {
    background: var(--rolo);
    transform: scale(1.1);
  }

  /* CTA closes the section — same ceremonial centering as section--what */
  .day__cta {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    text-align: center;
  }

  /* ===== SECTION 4 — HOW ================================================= */
  .section--how {
    background: var(--paper);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }
  .how__head { margin-bottom: clamp(2rem, 4vw, 3rem); }
  .how__title { margin-top: 1.25rem; margin-bottom: 1.25rem; }
  .how__lede { color: var(--ink); max-width: none; }

  /* Diagram comes first now — sits in its own framed surface, then the
     three pillars sit below it, lighter, no boxes. */
  .diagram {
    margin: 0 0 clamp(2.5rem, 5vw, 3.5rem);
    padding: 12px;
    background: var(--bg);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-pixel);
    position: relative;
  }
  .diagram__img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* Pillars — no boxes, no numbers. Title in the matching diagram colour
     acts as the call-out. A small colour chip and a 4px pixel-dashed rule
     above echo the diagram's bullet-square language. */
  .pillars {
    list-style: none;
    padding: 0;
    margin: 0 0 clamp(2rem, 5vw, 3rem);
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 4vw, 2.5rem);
  }
  @media (max-width: 900px) {
    .pillars { grid-template-columns: 1fr; gap: 2rem; }
  }
  .pillar {
    position: relative;
    padding-top: 0.85rem;
  }
  /* 4px pixel-dashed accent rule above each title — dash color follows the
     pillar's `color`, set by .pillar--voice/--status/--memory below. */
  .pillar::before {
    content: '';
    display: block;
    width: 40px;
    height: 4px;
    margin-bottom: 0.85rem;
    background: var(--pixel-dash);
  }
  .pillar--voice  { color: var(--sun-deep); }
  .pillar--status { color: var(--leaf-deep); }
  .pillar--memory { color: var(--moon-deep); }

  .pillar__chip { display: none; } /* reserved hook — the ::before rule carries the accent */

  .pillar__title {
    font-family: var(--body);
    font-weight: 700;
    font-size: clamp(1.1rem, 1.4vw, 1.3rem);
    letter-spacing: 0.02em;
    line-height: 1.2;
    color: currentColor;
    margin: 0 0 0.65rem;
  }
  .pillar__body {
    font-family: var(--body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink);
    margin: 0;
  }
  .pillar__body a {
    color: var(--rolo-deep);
    font-weight: 600;
  }

  /* Footer row — paragraph left, CTA right, wraps on mobile */
  .how__footer {
    margin-top: clamp(2rem, 4vw, 3rem);
    padding-top: 1.5rem;
    border-top: 1px dashed var(--rule);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    flex-wrap: wrap;
  }
  .how__more {
    font-family: var(--body);
    font-size: 1.05rem;
    color: var(--ink);
    margin: 0;
    max-width: 64ch;
  }
  .how__more a { color: var(--rolo-deep); font-weight: 600; }

  /* ===== SECTION 5 — GRAND FINALE ======================================== */
  /* Full-bleed orange field — the page's only saturated chromatic moment.
     The rest of the site is paper-on-warm-bg; here we flip the contract.
     Reads as a riso poster: corner registration marks, oversized stacked
     pixel headline, a hero sprite on a ground line that bookends the
     hero up top, and a paper-on-ink button framed by pixel chevrons. */
  /* Same warm-paper field as the rest of the page (body dotted-grid
     texture shows through). Left-aligned heading matching other sections;
     hero-sized Rolo sprite that swaps to happy on hover; orange CTA. */
  .section--finale {
    /* Divider above the footer now lives on .site-footer's border-top
       (set in Footer.astro) so every page gets it consistently. */
  }
  .finale__head {
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .finale__title {
    margin-top: 1.25rem;
  }
  .finale__title-rolo { color: var(--rolo); }

  /* Sprite + pixel ground line — echoes the hero composition. The sprite
     stays still by default and swaps to the happy frame on hover. */
  .finale__stage {
    display: grid;
    place-items: end center;
    margin-bottom: clamp(2rem, 4vw, 3rem);
  }
  .finale__rolo-swap {
    position: relative;
    display: inline-block;
    line-height: 0;
    cursor: pointer;
    text-decoration: none;
  }
  .finale__rolo {
    width: clamp(260px, 34vw, 460px);
    height: auto;
    image-rendering: pixelated;
    image-rendering: crisp-edges;
    /* Match the hero sprite shadow recipe — hard pixel + warm ambient */
    filter: drop-shadow(0 14px 0 rgba(42, 24, 16, 0.10))
            drop-shadow(0 24px 28px rgba(232, 101, 74, 0.22));
    transition: opacity 140ms var(--ease-soft);
  }
  .finale__rolo--happy {
    position: absolute;
    inset: 0;
    opacity: 0;
  }
  .finale__rolo-swap:hover .finale__rolo--idle,
  .finale__rolo-swap:focus-visible .finale__rolo--idle { opacity: 0; }
  .finale__rolo-swap:hover .finale__rolo--happy,
  .finale__rolo-swap:focus-visible .finale__rolo--happy { opacity: 1; }

  .finale__ground {
    width: min(72%, 380px);
    height: 4px;
    color: var(--ink); /* dash color (currentColor in the recipe) */
    background: var(--pixel-dash-tight);
    margin-top: 0.75rem;
  }

  .finale__cta {
    text-align: center;
  }
</style>

<script>
  // ===== Day-in-the-life carousel =======================================
  // Peek/active state machine. Active slide centered; prev/next slides
  // tilted on either side at lower opacity, click to navigate.
  // Keyboard arrows + touch swipe + counter + dots + arrow buttons.

  function initCarousel(root: HTMLElement) {
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    const prev   = root.querySelector<HTMLButtonElement>('[data-prev]');
    const next   = root.querySelector<HTMLButtonElement>('[data-next]');
    const parent = root.parentElement;
    const dots   = Array.from(parent?.querySelectorAll<HTMLElement>('[data-dot]') ?? []);
    if (slides.length === 0) return;

    const n = slides.length;
    let i = 0;

    function render() {
      slides.forEach((s, idx) => {
        s.classList.remove('is-active', 'is-prev', 'is-next');
        if (idx === i)            s.classList.add('is-active');
        else if (idx === i - 1)   s.classList.add('is-prev');
        else if (idx === i + 1)   s.classList.add('is-next');
        s.setAttribute('aria-hidden', idx === i ? 'false' : 'true');
      });

      dots.forEach((d, idx) => d.classList.toggle('is-active', idx === i));

      // disabled state on arrows at endpoints (v1 hover stays intact)
      if (prev) prev.toggleAttribute('disabled', i === 0);
      if (next) next.toggleAttribute('disabled', i === n - 1);
    }

    function go(target: number) {
      i = Math.max(0, Math.min(n - 1, target));
      render();
    }

    prev?.addEventListener('click', () => go(i - 1));
    next?.addEventListener('click', () => go(i + 1));

    // keyboard support — only when the carousel region is focused
    root.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); go(i - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); go(i + 1); }
    });

    // click prev/next peek slides to navigate to them
    slides.forEach((s, idx) => {
      s.addEventListener('click', () => {
        if (idx === i - 1 || idx === i + 1) go(idx);
      });
    });

    // dot click to jump
    dots.forEach((d, idx) => {
      d.setAttribute('role', 'button');
      d.setAttribute('aria-label', `Go to slide ${idx + 1}`);
      d.addEventListener('click', () => go(idx));
    });

    // touch swipe on the track
    const track = root.querySelector<HTMLElement>('[data-track]') ?? root;
    let startX = 0;
    track.addEventListener('touchstart', (e: TouchEvent) => {
      startX = e.touches[0].clientX;
    }, { passive: true });
    track.addEventListener('touchend', (e: TouchEvent) => {
      const dx = e.changedTouches[0].clientX - startX;
      if (Math.abs(dx) > 50) go(dx < 0 ? i + 1 : i - 1);
    });

    render();
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(initCarousel);
</script>
