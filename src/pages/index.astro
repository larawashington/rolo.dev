---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import WindowFrame from '../components/WindowFrame.astro';
import { LINKS } from '../lib/links';

const base = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : import.meta.env.BASE_URL + '/';

// Section 3 — carousel slides (exact copy from wireframe)
const slides = [
  {
    id: 'roaming',
    title: 'roaming.app',
    label: 'Roaming',
    src: `${base}gifs/rolo_walk_right.gif`,
    copy: 'Rolo walks across your screen and sees what you see. He will occasionally comment on your work and cheer you on.',
    alt: 'Rolo walking to the right across a small window',
    kind: 'gif' as const,
  },
  {
    id: 'eating',
    title: 'eating.app',
    label: 'Eating',
    src: `${base}gifs/rolo_eat.gif`,
    copy: 'Rolo is happiest when you’re happy, and second happiest when he gets to eat! Drag and drop files onto Rolo to feed him (eaten files go to Trash).',
    alt: 'Rolo munching on something',
    kind: 'gif' as const,
  },
  {
    id: 'chatting',
    title: 'chatting.app',
    label: 'Chatting',
    src: `${base}gifs/rolo_waiting.gif`,
    copy: 'Rolo loves to chat. Take a break and chat with Rolo about anything you like. As he learns more about you, he will remember important details you share for the future. Ask him about the weather!',
    alt: 'Rolo waiting patiently, ready for a chat',
    kind: 'gif' as const,
  },
  {
    id: 'sleeping',
    title: 'sleeping.app',
    label: 'Sleeping',
    /* No rolo_sleep.gif available — using static sprite per handoff */
    src: `${base}sprites/rolo-sleep.png`,
    copy: 'Rolo takes naps and dreams. Like us humans, this is when he processes and transfers information into his memory.',
    alt: 'Rolo curled up, asleep',
    kind: 'png' as const,
  },
];

// Section 2 — checklist items (exact copy from wireframe; first two = check, third = cross)
const checklist = [
  {
    kind: 'ok' as const,
    text: 'Rolo lives on your screen and keeps you company throughout everyday tasks. He acts as a positive counterbalance to our internal dialogues and anxieties.',
  },
  {
    kind: 'ok' as const,
    text: 'Rolo’s primary concern is your wellbeing and will do his best to bring out your best self. His secondary concern may be food-related. More on this later…',
  },
  {
    kind: 'no' as const,
    text: 'Rolo is NOT an AI assistant or tool. Do not confuse him with one (he will take offense). He will decline any requests that contradict his character and purpose of bringing joy and whimsy to your screen.',
  },
];
---
<Layout
  title="Project Rolo — a free, open-source desktop companion"
  description="Meet Rolo. A free, open-source desktop companion here to make your day a little brighter."
  pageId="home"
>
  <Header slot="header" />

  {/* ===== SECTION 1 — HERO ============================================== */}
  <section class="hero">
    <div class="shell hero__shell">

      <div class="hero__copy">
        <p class="eyebrow fade-up">a small companion &nbsp;//&nbsp; ch.00</p>

        <h1 class="pixel-h pixel-h--xl hero__title fade-up d1">
          Meet<br/><span class="hero__title-accent">Rolo.</span>
        </h1>

        <p class="lede hero__lede fade-up d2">
          A free, open-source desktop companion here to make your day
          a little brighter.
        </p>

        <div class="hero__cta fade-up d3" role="group" aria-label="Get Rolo">
          {/* PLACEHOLDER: downloadMac — see src/lib/links.ts */}
          <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
            Download Rolo
            <span class="hero__cta-meta">(mac)</span>
          </a>
          {/* PLACEHOLDER: repo */}
          <a class="btn btn--ghost btn--lg" href={LINKS.repo} target="_blank" rel="noopener">
            Explore the repo &rarr;
          </a>
        </div>
      </div>

      <div class="hero__stage fade-up d2">
        <img
          class="hero__rolo pixel"
          src={`${base}gifs/Rolo_idle.gif`}
          alt="Rolo, idle — a small pixel-art creature in a pointed red hood"
          width="520"
          height="520"
        />
        <div class="hero__ground" aria-hidden="true"></div>
        <p class="hero__floor-caption" aria-hidden="true">64 &times; 64 &middot; hand-drawn</p>
      </div>

    </div>
  </section>

  {/* ===== SECTION 2 — WHAT DOES ROLO DO? ================================ */}
  <section class="section section--what">
    <div class="shell">
      <header class="what__head">
        <p class="eyebrow fade-up">what he does &nbsp;//&nbsp; ch.01</p>
        <h2 class="pixel-h pixel-h--lg what__title fade-up d1">
          What does Rolo do?
        </h2>
      </header>

      <ul class="checklist">
        {checklist.map((item, i) => (
          <li class:list={['check', `check--${item.kind}`, 'fade-up']} style={`animation-delay:${(i + 1) * 110}ms`}>
            <span class="check__mark" aria-hidden="true">
              {item.kind === 'ok' ? (
                /* Pixel-style check — built from absolutely-positioned blocks
                   so it reads as hand-pixelled, not as a vector tick. */
                <svg viewBox="0 0 14 14" width="28" height="28" aria-hidden="true">
                  <g fill="currentColor" shape-rendering="crispEdges">
                    <rect x="1" y="6" width="2" height="2"/>
                    <rect x="3" y="8" width="2" height="2"/>
                    <rect x="5" y="10" width="2" height="2"/>
                    <rect x="7" y="8" width="2" height="2"/>
                    <rect x="9" y="6" width="2" height="2"/>
                    <rect x="11" y="4" width="2" height="2"/>
                  </g>
                </svg>
              ) : (
                <svg viewBox="0 0 14 14" width="28" height="28" aria-hidden="true">
                  <g fill="currentColor" shape-rendering="crispEdges">
                    <rect x="1" y="1" width="2" height="2"/>
                    <rect x="3" y="3" width="2" height="2"/>
                    <rect x="5" y="5" width="2" height="2"/>
                    <rect x="7" y="3" width="2" height="2"/>
                    <rect x="9" y="1" width="2" height="2"/>
                    <rect x="7" y="7" width="2" height="2"/>
                    <rect x="5" y="9" width="2" height="2"/>
                    <rect x="3" y="11" width="2" height="2"/>
                    <rect x="9" y="9" width="2" height="2"/>
                    <rect x="11" y="11" width="2" height="2"/>
                  </g>
                </svg>
              )}
            </span>
            <p class="check__text">{item.text}</p>
          </li>
        ))}
      </ul>

      <div class="what__cta">
        {/* PLACEHOLDER: downloadMac */}
        <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
          Invite Rolo to your desktop
        </a>
      </div>
    </div>
  </section>

  {/* ===== SECTION 3 — A DAY IN THE LIFE (CAROUSEL) ====================== */}
  <section class="section section--day" id="day">
    <div class="shell">
      <header class="day__head">
        <p class="eyebrow fade-up">a day in his life &nbsp;//&nbsp; ch.02</p>
        <h2 class="pixel-h pixel-h--lg day__title fade-up d1">
          A day in the life of Rolo
        </h2>
      </header>

      <div
        class="carousel"
        role="region"
        aria-roledescription="carousel"
        aria-label="Rolo's daily activities"
        tabindex="0"
        data-carousel
        data-count={slides.length}
      >
        <button
          class="carousel__arrow carousel__arrow--prev"
          type="button"
          aria-label="previous"
          data-prev
        >
          <svg viewBox="0 0 12 12" width="22" height="22" aria-hidden="true">
            <g fill="currentColor" shape-rendering="crispEdges">
              <rect x="7" y="2" width="2" height="2"/>
              <rect x="5" y="4" width="2" height="2"/>
              <rect x="3" y="6" width="2" height="2" style="display:none"/>
              <rect x="3" y="5" width="2" height="2"/>
              <rect x="5" y="6" width="2" height="2"/>
              <rect x="7" y="8" width="2" height="2"/>
            </g>
          </svg>
        </button>

        <div class="carousel__track" data-track>
          {slides.map((s, i) => (
            <article
              class="carousel__slide"
              data-slide
              data-index={i}
              aria-label={`Slide ${i + 1} of ${slides.length}: ${s.label}`}
            >
              <WindowFrame title={s.title}>
                <div class="slide-stage">
                  <img
                    class="slide-stage__img pixel"
                    src={s.src}
                    alt={s.alt}
                    loading={i === 0 ? 'eager' : 'lazy'}
                  />
                </div>
              </WindowFrame>

              <div class="slide-caption">
                <p class="slide-caption__label">{s.label}</p>
                <p class="slide-caption__copy">{s.copy}</p>
              </div>
            </article>
          ))}
        </div>

        <button
          class="carousel__arrow carousel__arrow--next"
          type="button"
          aria-label="next"
          data-next
        >
          <svg viewBox="0 0 12 12" width="22" height="22" aria-hidden="true">
            <g fill="currentColor" shape-rendering="crispEdges">
              <rect x="3" y="2" width="2" height="2"/>
              <rect x="5" y="4" width="2" height="2"/>
              <rect x="7" y="5" width="2" height="2"/>
              <rect x="5" y="6" width="2" height="2"/>
              <rect x="3" y="8" width="2" height="2"/>
            </g>
          </svg>
        </button>
      </div>

      <div class="carousel__dots" aria-hidden="true" data-dots>
        {slides.map((_, i) => (
          <span class:list={['carousel__dot', i === 0 && 'is-active']} data-dot={i}></span>
        ))}
      </div>

      <div class="day__cta">
        {/* PLACEHOLDER: downloadMac */}
        <a class="btn btn--primary btn--lg" href={LINKS.downloadMac}>
          Bring Rolo to life
        </a>
      </div>
    </div>
  </section>

  {/* ===== SECTION 4 — HOW DOES ROLO FUNCTION? =========================== */}
  <section class="section section--how">
    <div class="shell">
      <header class="how__head">
        <p class="eyebrow fade-up">behind the curtain &nbsp;//&nbsp; ch.03</p>
        <h2 class="pixel-h pixel-h--lg how__title fade-up d1">
          How does Rolo function?
        </h2>
        <p class="lede how__lede fade-up d2">
          Rolo lives locally on your machine and respects your privacy. He is powered by 3 pillars:
        </p>
      </header>

      <ol class="pillars">
        <li class="pillar fade-up d1">
          <span class="pillar__num" aria-hidden="true">01</span>
          <div class="pillar__body">
            <h3 class="pillar__title"><span class="t-rolo">Rolo&rsquo;s voice</span></h3>
            <p>
              comes from a fine-tuned
              <a href="https://deepmind.google/models/gemma/gemma-3/" target="_blank" rel="noopener">Gemma 3 4B</a>
              model. A small open-source large-language model trained on hand-seeded examples of how Rolo speaks.
            </p>
          </div>
        </li>
        <li class="pillar fade-up d2">
          <span class="pillar__num" aria-hidden="true">02</span>
          <div class="pillar__body">
            <h3 class="pillar__title"><span class="t-rolo">Rolo&rsquo;s status</span></h3>
            <p>
              is hardcoded and his mood depends on his hunger, social, energy, and happiness levels.
              This is combined with his perception of the activity on your screen to add flavor and relevance to his speech.
            </p>
          </div>
        </li>
        <li class="pillar fade-up d3">
          <span class="pillar__num" aria-hidden="true">03</span>
          <div class="pillar__body">
            <h3 class="pillar__title"><span class="t-rolo">Rolo&rsquo;s memory</span></h3>
            <p>
              is built through ongoing interactions with you. He remembers key information you share
              (names, events, preferences) and stores this into his memory while he sleeps and dreams.
            </p>
          </div>
        </li>
      </ol>

      <figure class="diagram">
        <img
          class="diagram__img pixel"
          src={`${base}rolo-how-it-works.png`}
          alt="Diagram of how Rolo works: three boxes hanging off Rolo — his Voice (a fine-tuned Gemma 3 4B model), his Status (mood from hunger, social and energy levels plus on-screen activity), and his Memory (the Vault, compiled when he dreams)."
          loading="lazy"
        />
        <figcaption>fig.00 &mdash; voice + status + memory = rolo</figcaption>
      </figure>

      <p class="how__more">
        To learn more about the system architecture of Rolo&rsquo;s soul,
        head to the <a href={LINKS.techProcess}>Tech + Process</a> page.
      </p>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ===== HERO ============================================================ */
  .hero {
    padding-top: clamp(2.5rem, 6vw, 5rem);
    padding-bottom: clamp(2rem, 5vw, 4rem);
    overflow: hidden;
    position: relative;
  }
  .hero__shell {
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(1.5rem, 5vw, 4rem);
    align-items: center;
    min-height: clamp(520px, 74vh, 720px);
  }
  @media (max-width: 900px) {
    .hero__shell {
      grid-template-columns: 1fr;
      align-items: stretch;
      min-height: unset;
      gap: 2rem;
    }
  }

  .hero__copy { max-width: 34rem; position: relative; z-index: 3; }
  .hero__title { margin: 1.25rem 0 1.5rem; }
  .hero__title-accent {
    color: var(--rolo);
    position: relative;
    display: inline-block;
  }
  .hero__title-accent::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -10px;
    height: 4px;
    background-image: linear-gradient(to right, var(--ink) 0 8px, transparent 8px 16px);
    background-size: 16px 4px;
  }
  .hero__lede { margin-bottom: 2.25rem; max-width: 34ch; }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    align-items: center;
  }
  .hero__cta-meta {
    font-family: var(--display);
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    opacity: 0.85;
    margin-left: 0.35rem;
  }

  /* Stage — Rolo on a ground line, breaking the grid */
  .hero__stage {
    position: relative;
    align-self: center;
    justify-self: center;
    width: 100%;
    display: grid;
    place-items: end center;
    padding-bottom: 2rem;
  }
  .hero__rolo {
    position: relative;
    z-index: 2;
    width: clamp(280px, 36vw, 520px);
    height: auto;
    /* hard pixel shadow + soft ambient — printmaking feel */
    filter: drop-shadow(0 14px 0 rgba(42, 24, 16, 0.10))
            drop-shadow(0 24px 28px rgba(232, 101, 74, 0.22));
    transform-origin: bottom center;
  }
  .hero__ground {
    width: min(86%, 460px);
    height: 4px;
    background-image: linear-gradient(to right, var(--ink) 0 8px, transparent 8px 14px);
    background-size: 14px 4px;
    margin-top: 0.5rem;
  }
  .hero__floor-caption {
    margin-top: 0.65rem;
    font-family: var(--display);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    text-transform: uppercase;
  }

  /* ===== SECTION 2 — WHAT ================================================ */
  .section--what {
    background: var(--paper);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }
  .what__head { margin-bottom: clamp(2rem, 4vw, 3rem); max-width: 48rem; }
  .what__title { margin-top: 1rem; }

  .checklist {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1rem;
    max-width: 62rem;
  }
  .check {
    background: var(--bg);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-pixel-sm);
    padding: 1.1rem 1.35rem;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: 1rem;
    align-items: start;
    transition: transform 200ms var(--ease-soft), box-shadow 200ms var(--ease-soft);
  }
  .check:hover { transform: translate(-2px, -2px); box-shadow: var(--shadow-pixel); }
  .check__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px; height: 40px;
    border: 2px solid var(--ink);
    background: var(--paper);
  }
  .check--ok .check__mark { color: var(--ok); }
  .check--no .check__mark { color: var(--no); }
  .check__text {
    font-family: var(--body);
    font-size: clamp(1rem, 0.5vw + 0.85rem, 1.1rem);
    line-height: 1.6;
    color: var(--ink);
    margin: 0.25rem 0;
  }

  .what__cta {
    margin-top: clamp(2rem, 4vw, 3rem);
  }

  /* ===== SECTION 3 — CAROUSEL ============================================ */
  .section--day {
    padding-bottom: clamp(3rem, 6vw, 5rem);
  }
  .day__head { margin-bottom: clamp(2rem, 4vw, 3rem); max-width: 48rem; }
  .day__title { margin-top: 1rem; }

  .carousel {
    position: relative;
    padding: 1rem 0 0.5rem;
  }
  .carousel:focus-visible { outline: 3px solid var(--rolo); outline-offset: 8px; }

  .carousel__track {
    display: flex;
    gap: clamp(1rem, 3vw, 2rem);
    align-items: stretch;
    transition: transform 500ms var(--ease-soft);
    will-change: transform;
    padding: 1rem 0;
  }

  .carousel__slide {
    flex: 0 0 60%;
    max-width: 640px;
    display: grid;
    grid-template-rows: auto 1fr;
    gap: 1.5rem;
  }
  @media (max-width: 880px) {
    .carousel__slide { flex-basis: 78%; }
  }
  @media (max-width: 560px) {
    .carousel__slide { flex-basis: 86%; }
  }

  .slide-stage {
    aspect-ratio: 5 / 4;
    background: var(--bg);
    border-bottom: 2px solid var(--ink);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(1rem, 4vw, 2.5rem);
    background-image: radial-gradient(circle at 1px 1px, rgba(42, 24, 16, 0.08) 1px, transparent 0);
    background-size: 6px 6px;
  }
  .slide-stage__img {
    width: auto;
    max-width: 70%;
    max-height: 80%;
    height: auto;
  }

  .slide-caption {
    padding: 0 0.25rem;
    text-align: center;
  }
  .slide-caption__label {
    font-family: var(--display);
    font-size: 0.8rem;
    letter-spacing: 0.06em;
    color: var(--rolo-deep);
    margin-bottom: 0.6rem;
  }
  .slide-caption__copy {
    font-family: var(--body);
    font-size: clamp(0.95rem, 0.4vw + 0.85rem, 1.05rem);
    line-height: 1.55;
    color: var(--ink);
    max-width: 48ch;
    margin: 0 auto;
  }

  /* Arrows — pixel-style chunky bordered buttons */
  .carousel__arrow {
    position: absolute;
    top: 38%;
    transform: translateY(-50%);
    width: 48px; height: 48px;
    background: var(--paper);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-pixel-sm);
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    z-index: 5;
    transition: transform 140ms var(--ease-soft),
                box-shadow 140ms var(--ease-soft),
                background 160ms var(--ease-soft);
  }
  .carousel__arrow:hover {
    transform: translate(-2px, calc(-50% - 2px));
    background: var(--rolo);
    color: var(--paper);
    box-shadow: 6px 6px 0 var(--ink);
  }
  .carousel__arrow:active {
    transform: translate(2px, calc(-50% + 2px));
    box-shadow: var(--shadow-pixel-press);
  }
  .carousel__arrow[disabled],
  .carousel__arrow[hidden] {
    opacity: 0;
    pointer-events: none;
  }
  .carousel__arrow--prev { left: -8px; }
  .carousel__arrow--next { right: -8px; }
  @media (min-width: 1024px) {
    .carousel__arrow--prev { left: -28px; }
    .carousel__arrow--next { right: -28px; }
  }

  /* Dots — progress indicator */
  .carousel__dots {
    display: flex;
    justify-content: center;
    gap: 10px;
    margin: 1.25rem 0 0;
  }
  .carousel__dot {
    width: 10px; height: 10px;
    background: var(--paper);
    border: 2px solid var(--ink);
    transition: background 160ms var(--ease-soft), transform 160ms var(--ease-soft);
  }
  .carousel__dot.is-active {
    background: var(--rolo);
    transform: scale(1.1);
  }

  .day__cta {
    margin-top: clamp(2rem, 4vw, 3rem);
    text-align: center;
  }

  /* ===== SECTION 4 — HOW ================================================= */
  .section--how {
    background: var(--paper);
    border-top: 2px solid var(--ink);
    border-bottom: 2px solid var(--ink);
  }
  .how__head { margin-bottom: clamp(2rem, 4vw, 3rem); max-width: 56rem; }
  .how__title { margin-top: 1rem; margin-bottom: 1.25rem; }
  .how__lede { color: var(--ink); }

  .pillars {
    list-style: none;
    padding: 0;
    margin: 0 0 clamp(2rem, 5vw, 3rem);
    display: grid;
    gap: 1rem;
    counter-reset: pillar;
  }
  .pillar {
    display: grid;
    grid-template-columns: auto 1fr;
    gap: 1.25rem;
    align-items: start;
    padding: 1.25rem 1.5rem;
    background: var(--bg);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-pixel-sm);
    transition: transform 200ms var(--ease-soft), box-shadow 200ms var(--ease-soft);
  }
  .pillar:hover {
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-pixel);
  }
  .pillar__num {
    font-family: var(--display);
    font-size: 1rem;
    color: var(--rolo);
    padding: 0.25rem 0.5rem;
    border: 2px solid var(--ink);
    background: var(--paper);
    align-self: start;
  }
  .pillar__title {
    font-family: var(--body);
    font-weight: 700;
    font-size: 1.15rem;
    margin-bottom: 0.4rem;
    color: var(--ink);
  }
  .t-rolo { color: var(--rolo-deep); }
  .pillar p {
    font-family: var(--body);
    font-size: 1rem;
    line-height: 1.6;
    color: var(--ink);
  }
  .pillar a { color: var(--rolo-deep); }

  .diagram {
    margin: clamp(2rem, 4vw, 3rem) 0 1.5rem;
    padding: 12px;
    background: var(--bg);
    border: 2px solid var(--ink);
    box-shadow: var(--shadow-pixel);
    position: relative;
  }
  .diagram__img {
    display: block;
    width: 100%;
    height: auto;
  }
  .diagram figcaption {
    font-family: var(--display);
    font-size: 0.55rem;
    letter-spacing: 0.18em;
    color: var(--ink-soft);
    margin-top: 14px;
    text-align: center;
  }

  .how__more {
    font-family: var(--body);
    font-size: 1.05rem;
    color: var(--ink);
    margin-top: 1.5rem;
    padding-top: 1.25rem;
    border-top: 1px dashed var(--rule);
  }
  .how__more a { color: var(--rolo-deep); font-weight: 600; }
</style>

<script>
  // ===== Carousel ========================================================
  // Vanilla JS, no framework. Keyboard arrows + click. Respects reduced motion.
  type CarouselEl = HTMLElement & { _state?: { i: number; n: number } };

  function initCarousel(root: CarouselEl) {
    const track = root.querySelector<HTMLElement>('[data-track]');
    const slides = Array.from(root.querySelectorAll<HTMLElement>('[data-slide]'));
    const prev = root.querySelector<HTMLButtonElement>('[data-prev]');
    const next = root.querySelector<HTMLButtonElement>('[data-next]');
    const dotsRoot = root.parentElement?.querySelector<HTMLElement>('[data-dots]') ??
                     root.parentElement?.querySelector<HTMLElement>('.carousel__dots');
    const dots = Array.from(root.parentElement?.querySelectorAll<HTMLElement>('[data-dot]') ?? []);
    if (!track || slides.length === 0) return;

    const n = slides.length;
    let i = 0;

    function applyState() {
      // peek/active class for opacity styling
      slides.forEach((s, idx) => {
        s.classList.toggle('is-active', idx === i);
        const win = s.querySelector<HTMLElement>('.window');
        if (win) {
          win.classList.toggle('window--peek', idx !== i);
          win.classList.toggle('window--active', idx === i);
        }
      });

      // translate the track so the active slide is centered
      const slide = slides[i];
      const containerRect = root.getBoundingClientRect();
      const slideRect = slide.getBoundingClientRect();
      const currentX = parseFloat(track!.dataset.x ?? '0');
      const slideCenter = (slideRect.left - containerRect.left) + slideRect.width / 2;
      const containerCenter = containerRect.width / 2;
      const delta = slideCenter - containerCenter;
      const newX = currentX - delta;
      track!.dataset.x = String(newX);
      track!.style.transform = `translateX(${newX}px)`;

      // arrow visibility (hide on first/last per wireframe)
      if (prev) prev.toggleAttribute('hidden', i === 0);
      if (next) next.toggleAttribute('hidden', i === n - 1);

      // dots
      dots.forEach((d, idx) => d.classList.toggle('is-active', idx === i));

      // a11y
      slides.forEach((s, idx) => {
        s.setAttribute('aria-hidden', idx === i ? 'false' : 'true');
      });
    }

    function go(delta: number) {
      i = Math.max(0, Math.min(n - 1, i + delta));
      applyState();
    }

    prev?.addEventListener('click', () => go(-1));
    next?.addEventListener('click', () => go(+1));

    // keyboard support — only when the carousel region is focused
    root.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'ArrowLeft')  { e.preventDefault(); go(-1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); go(+1); }
    });

    // dot click to jump
    dots.forEach((d, idx) => {
      d.style.cursor = 'pointer';
      d.setAttribute('role', 'button');
      d.setAttribute('aria-label', `Go to slide ${idx + 1}`);
      d.addEventListener('click', () => { i = idx; applyState(); });
    });

    // recompute on resize
    let raf = 0;
    window.addEventListener('resize', () => {
      cancelAnimationFrame(raf);
      raf = requestAnimationFrame(() => {
        // reset transform first so measurements are clean
        track!.style.transition = 'none';
        track!.dataset.x = '0';
        track!.style.transform = 'translateX(0)';
        requestAnimationFrame(() => {
          track!.style.transition = '';
          applyState();
        });
      });
    });

    // initial paint — wait a frame so layout is ready
    requestAnimationFrame(() => applyState());
  }

  document.querySelectorAll<HTMLElement>('[data-carousel]').forEach(el => initCarousel(el as CarouselEl));
</script>
