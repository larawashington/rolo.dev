---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import RoloSprite from '../components/RoloSprite.astro';
import SpeechBubble from '../components/SpeechBubble.astro';
import FeatureCard from '../components/FeatureCard.astro';
import ScreenshotFrame from '../components/ScreenshotFrame.astro';

// MVP — these download URLs are placeholders. Wire to GitHub Releases assets when ready.
const downloads = [
  { os: 'macOS',   ext: '.dmg',      href: '#',  size: '~6 MB' },
  { os: 'Windows', ext: '.msi',      href: '#',  size: '~7 MB' },
  { os: 'Linux',   ext: '.AppImage', href: '#',  size: '~8 MB' },
];

const features = [
  { icon: 'walk',  title: 'he walks',           body: 'Rolo wanders across your desktop on his own little legs. He picks paths, dawdles at corners, and never asks where you’re going.' },
  { icon: 'mouse', title: 'he notices you',     body: 'Move your cursor near him and he looks up. Hover too long and he gets curious. He’s shy, but he warms up.' },
  { icon: 'eat',   title: 'he eats files',      body: 'Drag a file onto Rolo and he’ll happily munch it down. He has opinions about leftovers, and a soft spot for screenshots.' },
  { icon: 'sleep', title: 'he rests too',       body: 'When you’re away, Rolo curls up and drifts off. He doesn’t pester, doesn’t notify, doesn’t want your attention — just your company.' },
] as const;
---
<Layout
  title="Rolo — your cosy desktop companion"
  description="A tiny pixel-art creature who lives on your desktop. He walks, he watches, he eats files. Free download for macOS, Windows, and Linux."
  pageId="home"
>
  <Header slot="header" />

  {/* ===== HERO ============================================================ */}
  <section class="hero">
    <div class="shell hero__grid">
      <div class="hero__copy">
        <p class="eyebrow fade-up">a tiny pixel companion &middot; v0.1 soon</p>
        <h1 class="hero__title fade-up d1">
          <span>meet</span>
          <span class="hero__title-rolo">rolo.</span>
        </h1>
        <p class="lede fade-up d2">
          He walks across your screen on tiny feet, peeks when you move the mouse,
          and eats the files you drag onto him. He doesn&rsquo;t notify, doesn&rsquo;t
          interrupt, doesn&rsquo;t ask for anything &mdash; he just keeps you company while
          you work.
        </p>

        <div class="hero__cta fade-up d3" role="group" aria-label="Download Rolo">
          {downloads.map((d, i) => (
            <a class={`btn ${i === 0 ? 'btn--primary' : ''}`} href={d.href} data-platform={d.os}>
              <svg class="platform-icon" viewBox="0 0 16 16" shape-rendering="crispEdges" aria-hidden="true">
                {d.os === 'macOS' && (
                  <g fill="currentColor">
                    <rect x="6" y="1" width="2" height="1"/>
                    <rect x="5" y="2" width="2" height="2"/>
                    <rect x="4" y="3" width="6" height="1"/>
                    <rect x="3" y="4" width="9" height="6"/>
                    <rect x="4" y="10" width="2" height="2"/>
                    <rect x="9" y="10" width="2" height="2"/>
                    <rect x="3" y="12" width="3" height="1"/>
                    <rect x="9" y="12" width="3" height="1"/>
                  </g>
                )}
                {d.os === 'Windows' && (
                  <g fill="currentColor">
                    <rect x="2" y="3" width="5" height="5"/>
                    <rect x="8" y="3" width="5" height="5"/>
                    <rect x="2" y="9" width="5" height="5"/>
                    <rect x="8" y="9" width="5" height="5"/>
                  </g>
                )}
                {d.os === 'Linux' && (
                  <g fill="currentColor">
                    <rect x="6" y="2" width="4" height="2"/>
                    <rect x="5" y="4" width="6" height="6"/>
                    <rect x="6" y="5" width="1" height="2"/>
                    <rect x="9" y="5" width="1" height="2"/>
                    <rect x="4" y="10" width="8" height="2"/>
                    <rect x="3" y="12" width="3" height="2"/>
                    <rect x="10" y="12" width="3" height="2"/>
                  </g>
                )}
              </svg>
              <span>
                {d.os === 'macOS' ? 'download for mac' : d.os === 'Windows' ? 'download for windows' : 'download for linux'}
                <span class="btn-meta">{d.ext} &middot; {d.size}</span>
              </span>
            </a>
          ))}
        </div>

        <p class="hero__fineprint fade-up d4">
          <span class="hero__pill">free &amp; open source</span>
          <span class="hero__sep">&middot;</span>
          <span>no account &middot; no telemetry &middot; lives entirely on your machine</span>
        </p>
      </div>

      {/* ---- Rolo + bubble cluster (anchored bottom-right of hero) ------- */}
      <div class="hero__creature" aria-hidden="false">
        <div class="hero__bubble fade-up d4">
          <SpeechBubble text="hi" tail="bottom-left" />
        </div>
        <div class="hero__rolo fade-up d3">
          <RoloSprite size={360} />
        </div>
      </div>

      {/* ---- Decorative pixel cloud motifs in negative space -------------- */}
      <div class="hero__decor" aria-hidden="true">
        <svg class="cloud cloud--a" viewBox="0 0 32 12" width="160" height="60" shape-rendering="crispEdges">
          <rect x="6" y="2" width="14" height="2" fill="#B5C8B0"/>
          <rect x="4" y="4" width="22" height="4" fill="#B5C8B0"/>
          <rect x="6" y="8" width="20" height="2" fill="#B5C8B0"/>
          <rect x="8" y="10" width="6" height="1" fill="#B5C8B0"/>
          <rect x="18" y="10" width="6" height="1" fill="#B5C8B0"/>
        </svg>
        <svg class="cloud cloud--b" viewBox="0 0 32 12" width="120" height="44" shape-rendering="crispEdges">
          <rect x="6" y="2" width="14" height="2" fill="#DDD2B6"/>
          <rect x="4" y="4" width="22" height="4" fill="#DDD2B6"/>
          <rect x="6" y="8" width="20" height="2" fill="#DDD2B6"/>
        </svg>
        <svg class="star star--a" viewBox="0 0 10 10" width="22" height="22" shape-rendering="crispEdges">
          <rect x="4" y="0" width="2" height="2" fill="#C9A961"/>
          <rect x="0" y="4" width="2" height="2" fill="#C9A961"/>
          <rect x="4" y="4" width="2" height="2" fill="#C9A961"/>
          <rect x="8" y="4" width="2" height="2" fill="#C9A961"/>
          <rect x="4" y="8" width="2" height="2" fill="#C9A961"/>
        </svg>
        <svg class="star star--b" viewBox="0 0 10 10" width="14" height="14" shape-rendering="crispEdges">
          <rect x="4" y="0" width="2" height="2" fill="#6B8E6F"/>
          <rect x="0" y="4" width="2" height="2" fill="#6B8E6F"/>
          <rect x="4" y="4" width="2" height="2" fill="#6B8E6F"/>
          <rect x="8" y="4" width="2" height="2" fill="#6B8E6F"/>
          <rect x="4" y="8" width="2" height="2" fill="#6B8E6F"/>
        </svg>
      </div>
    </div>

    {/* Pixel ground line — separates hero from the page below */}
    <svg class="hero__ground" viewBox="0 0 64 4" preserveAspectRatio="none" shape-rendering="crispEdges" aria-hidden="true">
      <rect x="0"  y="0" width="64" height="2" fill="#2C3E50"/>
      <rect x="0"  y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="4"  y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="8"  y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="12" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="16" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="20" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="24" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="28" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="32" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="36" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="40" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="44" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="48" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="52" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="56" y="2" width="2"  height="2" fill="#2C3E50"/>
      <rect x="60" y="2" width="2"  height="2" fill="#2C3E50"/>
    </svg>
  </section>

  {/* ===== WHAT IS ROLO? =================================================== */}
  <section class="section section--what">
    <div class="shell">
      <header class="section__head">
        <p class="eyebrow">&sect; 01 &mdash; about rolo</p>
        <h2 class="section__title">a small creature.<br/><span class="t-sage">a quiet companion.</span></h2>
        <p class="lede">
          Rolo isn&rsquo;t a chatbot, a productivity tool, or a notification machine.
          He&rsquo;s a tiny living thing made of 64 by 64 pixels, who shares your screen
          and asks for nothing in return.
        </p>
      </header>

      <div class="feature-grid">
        {features.map((f, i) => (
          <FeatureCard
            icon={f.icon}
            title={f.title}
            body={f.body}
            delay={i * 120}
          />
        ))}
      </div>
    </div>
  </section>

  {/* ===== HOW IT WORKS ==================================================== */}
  <section class="section section--how">
    <div class="shell">
      <header class="section__head section__head--centered">
        <p class="eyebrow">&sect; 02 &mdash; how it works</p>
        <h2 class="section__title">install. say hi.<br/><span class="t-sage">that&rsquo;s about it.</span></h2>
        <p class="lede">
          Drag the download to your Applications folder (or equivalent), open Rolo once,
          and he&rsquo;ll find a comfortable corner of your screen. He doesn&rsquo;t need
          permissions, accounts, or setup steps.
        </p>
      </header>

      <div class="screens">
        <ScreenshotFrame caption="rolo wanders your desktop, minding his own little business." variant="desktop" delay={80} />
        <ScreenshotFrame caption="closer look: 64×64 pixels, six colours, every edge hand-placed." variant="closeup" delay={200} />
        <ScreenshotFrame caption="drag a file onto him — he eats it and looks pleased with himself." variant="desktop" delay={320} />
      </div>
    </div>
  </section>

  {/* ===== CLOSING CTA ====================================================== */}
  <section class="section section--closing">
    <div class="shell">
      <div class="closing-card panel">
        <div class="closing-card__copy">
          <p class="eyebrow">ready when you are</p>
          <h2 class="closing-card__title">bring him home.</h2>
          <p class="lede" style="color:var(--text);">
            Rolo is free, open source, and roughly the size of a postcard pinned to your
            corner of the screen. He&rsquo;d love to meet you.
          </p>
          <div class="hero__cta" role="group" aria-label="Download Rolo">
            <a class="btn btn--primary" href="#">
              <span>download rolo<span class="btn-meta">free &middot; v0.1 soon</span></span>
            </a>
            <a class="btn btn--ghost" href="https://github.com/larawashington/Desktop-Pet" target="_blank" rel="noopener">
              <span>view source &rarr;</span>
            </a>
          </div>
        </div>
        <div class="closing-card__rolo" aria-hidden="true">
          <RoloSprite size={140} />
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ===== HERO ============================================================ */
  .hero {
    position: relative;
    padding-top: clamp(2rem, 6vw, 5rem);
    padding-bottom: 0;
    overflow: hidden;
  }

  .hero__grid {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
    gap: clamp(1rem, 4vw, 4rem);
    align-items: end;
    min-height: clamp(540px, 78vh, 760px);
  }
  @media (max-width: 900px) {
    .hero__grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
      align-items: stretch;
      min-height: unset;
    }
  }

  .hero__copy {
    padding-top: clamp(1rem, 4vw, 3rem);
    padding-bottom: clamp(2rem, 6vw, 4rem);
    max-width: 38rem;
    position: relative;
    z-index: 3;
  }
  .hero__title {
    font-family: 'Silkscreen', monospace;
    font-weight: 700;
    font-size: clamp(2.8rem, 6.5vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.01em;
    margin-bottom: 1.5rem;
    color: var(--navy);
    display: flex;
    flex-direction: column;
    gap: 0.1em;
  }
  .hero__title-rolo {
    color: var(--sage-deep);
    position: relative;
    display: inline-block;
    width: fit-content;
  }
  .hero__title-rolo::after {
    content: '';
    position: absolute;
    left: 0; right: 0; bottom: -10px;
    height: 6px;
    background-image: linear-gradient(
      to right,
      var(--rolo) 0 14px,
      transparent 14px 24px
    );
    background-size: 24px 6px;
  }

  .hero__cta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 2rem;
    margin-bottom: 1.5rem;
  }

  .hero__fineprint {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem;
    font-family: 'VT323', monospace;
    font-size: 1.15rem;
    color: var(--navy-soft);
    letter-spacing: 0.04em;
  }
  .hero__pill {
    display: inline-block;
    padding: 0.15rem 0.55rem 0.2rem;
    background: var(--sage);
    color: var(--bg);
    border: 2px solid var(--navy);
    box-shadow: 2px 2px 0 var(--navy);
    text-transform: lowercase;
    letter-spacing: 0.08em;
  }
  .hero__sep { color: var(--surface-2); }

  /* Creature cluster — sits in the right column on desktop, wrapped below on mobile */
  .hero__creature {
    position: relative;
    align-self: end;
    justify-self: end;
    padding-right: clamp(0rem, 2vw, 2rem);
    min-height: 380px;
    width: 100%;
    display: grid;
    place-items: end;
  }
  @media (max-width: 900px) {
    .hero__creature {
      justify-self: center;
      padding-right: 0;
      min-height: 320px;
    }
  }

  .hero__rolo {
    position: relative;
    z-index: 2;
    transform-origin: bottom center;
  }
  .hero__rolo :global(.rolo-sprite) {
    width: clamp(240px, 30vw, 380px);
    height: auto;
  }

  .hero__bubble {
    position: absolute;
    top: -10px;
    right: clamp(160px, 22vw, 260px);
    z-index: 3;
  }
  @media (max-width: 900px) {
    .hero__bubble {
      top: -20px;
      right: 30%;
    }
  }

  /* Decorative clouds and stars floating in the hero negative space */
  .hero__decor {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
  }
  .cloud, .star {
    position: absolute;
    opacity: 0.7;
  }
  .cloud--a {
    top: 12%;
    right: 8%;
    animation: cloud-drift 22s linear infinite alternate;
  }
  .cloud--b {
    top: 38%;
    left: 42%;
    opacity: 0.55;
    animation: cloud-drift 28s linear infinite alternate-reverse;
  }
  .star--a {
    top: 6%;
    left: 8%;
    animation: blink 5.4s ease-in-out infinite;
  }
  .star--b {
    top: 22%;
    left: 30%;
    animation: blink 7.1s ease-in-out infinite;
  }
  @media (max-width: 900px) {
    .cloud--b, .star--b { display: none; }
  }

  /* Hero ground line — the pixel rule Rolo "stands on" */
  .hero__ground {
    display: block;
    width: 100%;
    height: 10px;
    margin-top: -1px;
  }

  /* ===== Generic section ================================================== */
  .section {
    padding: clamp(4rem, 8vw, 7rem) 0;
    position: relative;
  }
  .section--what  { background: linear-gradient(180deg, var(--bg) 0%, var(--bg-tint) 100%); }
  .section--how   { background: var(--bg); }
  .section--closing { padding-bottom: clamp(3rem, 6vw, 5rem); }

  .section__head {
    max-width: 56rem;
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .section__head--centered {
    margin-inline: auto;
    text-align: center;
  }
  .section__head--centered .lede { margin-inline: auto; }

  .section__title {
    font-family: 'Silkscreen', monospace;
    font-size: clamp(2rem, 4.4vw, 3.6rem);
    line-height: 1.05;
    color: var(--navy);
    margin-bottom: 1.25rem;
    letter-spacing: -0.005em;
  }
  .t-sage { color: var(--sage-deep); }

  /* Feature grid */
  .feature-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 1.5rem;
  }

  /* Screenshot grid */
  .screens {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    grid-template-rows: auto auto;
    gap: 1.5rem;
  }
  .screens > :nth-child(1) { grid-column: 1; grid-row: 1 / 3; }
  .screens > :nth-child(2) { grid-column: 2; grid-row: 1; }
  .screens > :nth-child(3) { grid-column: 2; grid-row: 2; }
  @media (max-width: 720px) {
    .screens { grid-template-columns: 1fr; grid-template-rows: auto; }
    .screens > * { grid-column: auto !important; grid-row: auto !important; }
  }

  /* Closing card — full-width panel with Rolo on the right */
  .closing-card {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 2.5rem;
    align-items: center;
    padding: clamp(2rem, 4vw, 3.5rem);
    background: var(--surface);
    position: relative;
    overflow: hidden;
  }
  .closing-card::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 80% 20%, rgba(201, 169, 97, 0.18), transparent 40%),
      radial-gradient(circle at 10% 80%, rgba(107, 142, 111, 0.18), transparent 50%);
    pointer-events: none;
  }
  .closing-card > * { position: relative; }

  .closing-card__title {
    font-family: 'Silkscreen', monospace;
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    color: var(--navy);
    line-height: 1.05;
    margin-bottom: 1rem;
  }
  .closing-card__rolo {
    align-self: end;
  }
  .closing-card__rolo :global(.rolo-sprite) {
    width: clamp(110px, 14vw, 160px);
    height: auto;
  }
  @media (max-width: 720px) {
    .closing-card { grid-template-columns: 1fr; }
    .closing-card__rolo { justify-self: center; }
  }
</style>
